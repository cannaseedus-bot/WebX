{
  "class": "TeamLeadActions",
  "methods": {
    "assign_tasks": {
      "params": ["goal", "constraints"],
      "body": [
        {
          "op": "set",
          "var": "board",
          "value": {
            "goal": "$goal",
            "constraints": "$constraints",
            "tasks": [],
            "status": "planning"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "team-lead.assign",
            "board": "$board"
          }
        }
      ]
    },
    "dispatch_agents": {
      "params": ["tasks", "parallel"],
      "body": [
        {
          "op": "set",
          "var": "dispatch",
          "value": {
            "tasks": "$tasks",
            "parallel": "$parallel",
            "status": "dispatched"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "team-lead.dispatch",
            "dispatch": "$dispatch"
          }
        }
      ]
    },
    "update_board": {
      "params": ["taskId", "status", "agent", "result"],
      "body": [
        {
          "op": "set",
          "var": "update",
          "value": {
            "taskId": "$taskId",
            "status": "$status",
            "agent": "$agent",
            "result": "$result"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "team-lead.board.update",
            "update": "$update"
          }
        }
      ]
    },
    "get_board": {
      "params": [],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "team-lead.board.get"
          }
        }
      ]
    },
    "synthesize": {
      "params": ["results", "goal"],
      "body": [
        {
          "op": "set",
          "var": "summary",
          "value": {
            "goal": "$goal",
            "results": "$results",
            "status": "synthesized"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "team-lead.synthesize",
            "summary": "$summary"
          }
        }
      ]
    },
    "complete_task": {
      "params": ["taskId", "artifact"],
      "body": [
        {
          "op": "set",
          "var": "completion",
          "value": {
            "taskId": "$taskId",
            "artifact": "$artifact",
            "status": "completed"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "team-lead.task.complete",
            "completion": "$completion"
          }
        }
      ]
    },
    "block_task": {
      "params": ["taskId", "blockedBy", "reason"],
      "body": [
        {
          "op": "set",
          "var": "update",
          "value": {
            "taskId": "$taskId",
            "blockedBy": "$blockedBy",
            "reason": "$reason",
            "status": "blocked"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "team-lead.task.block",
            "block": "$update"
          }
        }
      ]
    }
  }
}
