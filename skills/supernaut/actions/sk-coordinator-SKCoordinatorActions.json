{
  "class": "SKCoordinatorActions",
  "methods": {
    "parse_intent": {
      "params": ["utterance"],
      "body": [
        {
          "op": "set",
          "var": "intent",
          "value": "meta.plan"
        },
        {
          "op": "set",
          "var": "confidence",
          "value": 0.5
        },
        {
          "op": "if",
          "cond": {
            "var": "utterance"
          },
          "then": [
            {
              "op": "set",
              "var": "intent",
              "value": "schedule.learning"
            },
            {
              "op": "set",
              "var": "confidence",
              "value": 0.92
            }
          ]
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "semantic.intent.parse",
            "intent": "$intent",
            "confidence": "$confidence",
            "entities": {
              "utterance": "$utterance"
            }
          }
        }
      ]
    },
    "schedule_learning_goal": {
      "params": ["topic", "timeframe"],
      "body": [
        {
          "op": "set",
          "var": "learningPlan",
          "value": {
            "topic": "$topic",
            "timeframe": "$timeframe",
            "milestones": [
              "Understand bean scopes",
              "Wire constructor injection",
              "Integrate with agent bridge"
            ],
            "reviewCycle": "every 3 days"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "semantic.learning.schedule",
            "plan": "$learningPlan"
          }
        }
      ]
    },
    "route_to_micronaut": {
      "params": ["dependency", "action"],
      "body": [
        {
          "op": "set",
          "var": "diPlan",
          "value": {
            "dependency": "$dependency",
            "action": "$action",
            "steps": [
              "Check bean availability",
              "Resolve constructor dependencies",
              "Bind lifecycle hooks",
              "Return DI handle"
            ]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "semantic.micronaut.orchestrate",
            "plan": "$diPlan"
          }
        }
      ]
    },
    "build_goal_graph": {
      "params": ["objective"],
      "body": [
        {
          "op": "set",
          "var": "goalGraph",
          "value": {
            "root": "$objective",
            "nodes": [
              "Define schema",
              "Wire DI",
              "Implement runtime",
              "Integrate agents"
            ],
            "edges": [
              [
                "Define schema",
                "Wire DI"
              ],
              [
                "Wire DI",
                "Implement runtime"
              ],
              [
                "Implement runtime",
                "Integrate agents"
              ]
            ]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "semantic.goalgraph.build",
            "goalGraph": "$goalGraph"
          }
        }
      ]
    }
  }
}
