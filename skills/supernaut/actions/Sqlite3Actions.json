{
  "class": "Sqlite3Actions",
  "methods": {
    "open": {
      "params": ["dbPath", "mode"],
      "body": [
        {
          "op": "set",
          "var": "dbHandle",
          "value": {
            "path": "$dbPath",
            "mode": "$mode",
            "status": "opened",
            "wal": true
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sqlite3.open",
              "mode": "deterministic"
            },
            "handle": "$dbHandle"
          }
        }
      ]
    },
    "query": {
      "params": ["dbPath", "sql", "params"],
      "body": [
        {
          "op": "set",
          "var": "queryCtx",
          "value": {
            "db": "$dbPath",
            "sql": "$sql",
            "params": "$params"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sqlite3.query",
              "mode": "deterministic"
            },
            "query": "$queryCtx",
            "rows": [],
            "rowCount": 0
          }
        }
      ]
    },
    "fts5_query": {
      "params": ["dbPath", "table", "matchExpr"],
      "body": [
        {
          "op": "set",
          "var": "ftsCtx",
          "value": {
            "db": "$dbPath",
            "table": "$table",
            "match": "$matchExpr"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sqlite3.fts5_query",
              "mode": "deterministic"
            },
            "fts": "$ftsCtx",
            "rows": [],
            "rowCount": 0
          }
        }
      ]
    },
    "backup": {
      "params": ["srcPath", "destPath"],
      "body": [
        {
          "op": "set",
          "var": "backupJob",
          "value": {
            "src": "$srcPath",
            "dest": "$destPath",
            "status": "completed"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sqlite3.backup",
              "mode": "deterministic"
            },
            "backup": "$backupJob"
          }
        }
      ]
    },
    "pack_checkpoint_shard": {
      "params": ["dbPath", "table", "shardOut"],
      "body": [
        {
          "op": "set",
          "var": "shardJob",
          "value": {
            "db": "$dbPath",
            "table": "$table",
            "output": "$shardOut",
            "format": "scxqdds",
            "status": "packed"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sqlite3.pack_checkpoint_shard",
              "mode": "deterministic"
            },
            "shard": "$shardJob"
          }
        }
      ]
    }
  }
}
