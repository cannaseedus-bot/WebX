{
  "version": "1.0",
  "domain": "micronaut-factory",
  "actions": [
    {
      "id": "CreateMicronaut",
      "intent": "user_creates_micronaut",
      "name": "Create Micronaut",
      "description": "Create a new executable micronaut agent from JSON schema blueprint",
      "trigger": ["create micronaut", "new agent from schema", "scaffold micronaut"],
      "input": {
        "schema_path": {
          "type": "string",
          "description": "Path to schema JSON file (e.g., schemas/matmul.json)",
          "required": true
        },
        "backend": {
          "type": "enum",
          "values": ["deterministic", "semantic", "composite"],
          "default": "deterministic",
          "description": "Execution backend type"
        }
      },
      "output": {
        "instance_id": {
          "type": "string",
          "description": "mna://namespace/name@version"
        },
        "packet_hash": {
          "type": "string",
          "description": "SHA-256 hash of executable packet"
        },
        "packet_size": {
          "type": "uint32",
          "description": "Size in bytes"
        }
      },
      "handler": "factory_coordinator_bot.MicronauntFactoryCoordinator.create_from_file"
    },
    {
      "id": "PublishMicronaut",
      "intent": "user_publishes_micronaut",
      "name": "Publish Micronaut",
      "description": "Publish micronaut to mesh peers for replication",
      "trigger": ["publish micronaut", "replicate agent", "deploy micronaut"],
      "input": {
        "instance_id": {
          "type": "string",
          "description": "mna:// URI",
          "required": true
        },
        "replica_count": {
          "type": "uint32",
          "default": 3,
          "description": "Number of mesh replicas"
        }
      },
      "output": {
        "published": {
          "type": "boolean",
          "description": "Success"
        },
        "replicas": {
          "type": "uint32",
          "description": "Actual replicas deployed"
        }
      },
      "handler": "factory_coordinator_bot.MicronauntFactoryCoordinator.publish"
    },
    {
      "id": "ResolveMicronaut",
      "intent": "user_resolves_micronaut",
      "name": "Resolve Micronaut",
      "description": "Resolve mna:// URI to executable instance",
      "trigger": ["resolve micronaut", "lookup agent", "get micronaut"],
      "input": {
        "mna_uri": {
          "type": "string",
          "description": "mna://namespace/name@version",
          "required": true
        }
      },
      "output": {
        "instance": {
          "type": "object",
          "description": "MicronauntInstance (id, hash, backend, etc.)"
        }
      },
      "handler": "factory_coordinator_bot.MicronauntFactoryCoordinator.resolve"
    },
    {
      "id": "ComposeMicronauts",
      "intent": "user_composes_micronauts",
      "name": "Compose Micronauts",
      "description": "Compose multiple micronauts into a single composite agent",
      "trigger": ["compose micronauts", "combine agents", "merge micronauts"],
      "input": {
        "instance_ids": {
          "type": "string[]",
          "description": "List of mna:// URIs",
          "required": true
        },
        "composition_name": {
          "type": "string",
          "description": "Name for composed agent",
          "required": true
        }
      },
      "output": {
        "composed_id": {
          "type": "string",
          "description": "mna://composed/name@1.0.0"
        },
        "packet_hash": {
          "type": "string"
        }
      },
      "handler": "factory_coordinator_bot.MicronauntFactoryCoordinator.compose"
    },
    {
      "id": "ListMicronauts",
      "intent": "user_lists_micronauts",
      "name": "List Micronauts",
      "description": "List all created micronauts",
      "trigger": ["list micronauts", "show agents", "what micronauts"],
      "input": {},
      "output": {
        "instances": {
          "type": "object[]",
          "description": "Array of MicronauntInstance objects"
        }
      },
      "handler": "factory_coordinator_bot.MicronauntFactoryCoordinator.list_instances"
    },
    {
      "id": "GetFactoryStats",
      "intent": "user_gets_factory_stats",
      "name": "Get Factory Statistics",
      "description": "Get factory creation statistics",
      "trigger": ["factory stats", "micronaut stats", "how many created"],
      "input": {},
      "output": {
        "total_created": {"type": "uint32"},
        "total_registered": {"type": "uint32"},
        "backends": {
          "type": "object",
          "description": "Count per backend type"
        }
      },
      "handler": "factory_coordinator_bot.MicronauntFactoryCoordinator.get_stats"
    }
  ]
}
