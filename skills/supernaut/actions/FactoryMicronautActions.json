{
  "class": "FactoryMicronautActions",
  "methods": {
    "build": {
      "params": ["template", "name", "config"],
      "body": [
        {"op": "set", "var": "req", "value": {"template": "$template", "name": "$name", "config": "$config"}},
        {"op": "json", "value": {"ok": true, "execution": "factory-micronaut.build", "request": "$req"}}
      ]
    },
    "templates": {
      "params": [],
      "body": [{"op": "json", "value": {"ok": true, "execution": "factory-micronaut.templates"}}]
    },
    "health": {
      "params": [],
      "body": [{"op": "json", "value": {"ok": true, "execution": "factory-micronaut.health", "port": 3148}}]
    },
    "metrics": {
      "params": [],
      "body": [{"op": "json", "value": {"ok": true, "execution": "factory-micronaut.metrics", "port": 3148}}]
    }
  }
}