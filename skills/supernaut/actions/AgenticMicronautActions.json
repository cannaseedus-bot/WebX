{
  "class": "AgenticMicronautActions",
  "methods": {
    "arbitrate": {
      "params": ["intent", "candidates"],
      "body": [
        {"op": "set", "var": "arb", "value": {"intent": "$intent", "candidates": "$candidates"}},
        {"op": "json", "value": {"ok": true, "execution": "agentic-micronaut.arbitrate", "arbitration": "$arb"}}
      ]
    },
    "projectSkill": {
      "params": ["skill", "target_dir"],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "agentic-micronaut.project_skill", "skill": "$skill", "target": "$target_dir"}}
      ]
    },
    "resolveAgent": {
      "params": ["agent_name"],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "agentic-micronaut.resolve_agent", "agent": "$agent_name"}}
      ]
    },
    "listRegistry": {
      "params": [],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "agentic-micronaut.list_registry"}}
      ]
    },
    "packShard": {
      "params": ["manifest", "output"],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "agentic-micronaut.pack_shard", "manifest": "$manifest", "output": "$output"}}
      ]
    }
  }
}