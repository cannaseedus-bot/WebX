            resultArea.appendChild(steps);

            resultArea.appendChild(lbl("RESOLVE OPCODE PLAN"));
            const plan=order.map(id=>({...{"@op":"PLUGIN_LOAD","id":id}}));
            plan.push({"@op":"PLUGIN_EXEC","id":plugin.id,"entry":plugin.entry});
            resultArea.appendChild(pre({"@plan":plan}));
          }

          if(PLUGINS.length)doResolve(PLUGINS[0]);
        }

