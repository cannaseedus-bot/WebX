{
  "class": "MicronautDIActions",
  "methods": {
    "inject_component": {
      "params": ["component", "target"],
      "body": [
        {
          "op": "load",
          "from": "../micronaut/config/application.json",
          "into": "context"
        },
        {
          "op": "set",
          "var": "bindings",
          "value": "$context.components"
        },
        {
          "op": "setProp",
          "target": "$bindings",
          "path": "$component",
          "value": {
            "target": "$target",
            "scope": "singleton",
            "status": "wired"
          }
        },
        {
          "op": "json",
          "value": {
            "intent": "micronaut.di.inject",
            "component": "$component",
            "target": "$target",
            "bindings": "$bindings"
          }
        }
      ]
    }
  }
}
