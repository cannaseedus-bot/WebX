{
  "class": "FigmaImplementDesignActions",
  "methods": {
    "frame_to_react": {
      "params": ["fileKey", "nodeId", "componentName"],
      "body": [
        {
          "op": "set",
          "var": "reactCtx",
          "value": {
            "fileKey": "$fileKey",
            "nodeId": "$nodeId",
            "componentName": "$componentName",
            "framework": "react",
            "status": "generated"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma-implement-design.frame_to_react",
              "mode": "deterministic"
            },
            "component": "$reactCtx",
            "code": ""
          }
        }
      ]
    },
    "frame_to_html": {
      "params": ["fileKey", "nodeId"],
      "body": [
        {
          "op": "set",
          "var": "htmlCtx",
          "value": {
            "fileKey": "$fileKey",
            "nodeId": "$nodeId",
            "framework": "html-css",
            "status": "generated"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma-implement-design.frame_to_html",
              "mode": "deterministic"
            },
            "output": "$htmlCtx",
            "html": "",
            "css": ""
          }
        }
      ]
    },
    "map_tokens": {
      "params": ["fileKey", "designSystem"],
      "body": [
        {
          "op": "set",
          "var": "tokenMap",
          "value": {
            "fileKey": "$fileKey",
            "designSystem": "$designSystem",
            "status": "mapped"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma-implement-design.map_tokens",
              "mode": "deterministic"
            },
            "tokenMap": "$tokenMap"
          }
        }
      ]
    },
    "emit_component": {
      "params": ["componentSpec", "targetPath"],
      "body": [
        {
          "op": "set",
          "var": "emitCtx",
          "value": {
            "spec": "$componentSpec",
            "target": "$targetPath",
            "status": "emitted"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma-implement-design.emit_component",
              "mode": "deterministic"
            },
            "emit": "$emitCtx"
          }
        }
      ]
    },
    "sync_styles": {
      "params": ["fileKey", "targetConfig"],
      "body": [
        {
          "op": "set",
          "var": "syncCtx",
          "value": {
            "fileKey": "$fileKey",
            "target": "$targetConfig",
            "status": "synced"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma-implement-design.sync_styles",
              "mode": "deterministic"
            },
            "sync": "$syncCtx"
          }
        }
      ]
    }
  }
}
