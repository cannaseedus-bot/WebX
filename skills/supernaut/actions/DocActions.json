{
  "class": "DocActions",
  "methods": {
    "generate_readme": {
      "params": ["projectName", "description"],
      "body": [
        {
          "op": "set",
          "var": "readme",
          "value": {
            "project": "$projectName",
            "description": "$description",
            "status": "generated"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "doc.generate_readme",
              "mode": "deterministic"
            },
            "readme": "$readme"
          }
        }
      ]
    },
    "update_api_ref": {
      "params": ["apiPath", "spec"],
      "body": [
        {
          "op": "set",
          "var": "apiRef",
          "value": {
            "path": "$apiPath",
            "spec": "$spec",
            "status": "updated"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "doc.update_api_ref",
              "mode": "deterministic"
            },
            "apiRef": "$apiRef"
          }
        }
      ]
    },
    "write_changelog": {
      "params": ["version", "entries"],
      "body": [
        {
          "op": "set",
          "var": "changelog",
          "value": {
            "version": "$version",
            "entries": "$entries",
            "status": "written"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "doc.write_changelog",
              "mode": "deterministic"
            },
            "changelog": "$changelog"
          }
        }
      ]
    },
    "draw_diagram": {
      "params": ["diagramType", "components"],
      "body": [
        {
          "op": "set",
          "var": "diagram",
          "value": {
            "type": "$diagramType",
            "components": "$components",
            "status": "rendered"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "doc.draw_diagram",
              "mode": "deterministic"
            },
            "diagram": "$diagram"
          }
        }
      ]
    },
    "validate_links": {
      "params": ["docPath"],
      "body": [
        {
          "op": "set",
          "var": "validation",
          "value": {
            "docPath": "$docPath",
            "status": "validated",
            "brokenLinks": []
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "doc.validate_links",
              "mode": "deterministic"
            },
            "validation": "$validation"
          }
        }
      ]
    }
  }
}
