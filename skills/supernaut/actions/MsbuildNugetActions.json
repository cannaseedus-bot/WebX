{
  "class": "MsbuildNugetActions",
  "methods": {
    "query": {
      "params": ["topic"],
      "body": [
        {
          "op": "set",
          "var": "info",
          "value": {
            "topic": "$topic",
            "root": "C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\MSBuild\\Microsoft\\NuGet\\17.0",
            "tasksDll": "Microsoft.NuGet.Build.Tasks.dll",
            "nugetProps": "Microsoft.NuGet.props",
            "nugetTargets": "Microsoft.NuGet.targets",
            "jsonNetDll": "Newtonsoft.Json.dll",
            "msbuildNugetTasksVersion": "17.2.0-prerelease.23116.1",
            "jsonNetVersion": "13.0.1"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "msbuild-nuget.query",
              "mode": "deterministic"
            },
            "info": "$info"
          }
        }
      ]
    },
    "debug_restore": {
      "params": ["projectPath", "errorMsg"],
      "body": [
        {
          "op": "set",
          "var": "diagnosis",
          "value": {
            "project": "$projectPath",
            "error": "$errorMsg",
            "suggestions": [
              "Check project.assets.json in obj/ for restore errors",
              "Ensure PackageReference versions are compatible",
              "Verify NuGet.Config feed sources are reachable",
              "Run: dotnet restore --verbosity detailed"
            ]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "msbuild-nuget.debug_restore",
              "mode": "deterministic"
            },
            "diagnosis": "$diagnosis"
          }
        }
      ]
    }
  }
}
