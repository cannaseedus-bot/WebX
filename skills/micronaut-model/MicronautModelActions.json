{
  "backends": {
    "summary": "All 7 supported micronaut weight backends with field schemas and selection guide.",
    "backends": {
      "local_gguf": {
        "description": "Local GGUF or MGGUF weight file. GPU-accelerated via llama-cpp-python.",
        "runtime_dep": "pip install llama-cpp-python",
        "required_fields": ["path"],
        "optional_fields": ["hash", "vocab_size", "num_layers", "hidden_size", "context_length", "quantization"],
        "example_path": "models/my-model.gguf",
        "latency": "< 100ms first token (GPU)",
        "use_when": "Local file ready, offline required, or lowest latency needed"
      },
      "local_scxqdds": {
        "description": "SCXQDDS INT8 tensor shards from the native AS-XCFE pipeline.",
        "runtime_dep": "artifacts/native-asx/scxqdds_vector_runner.exe",
        "required_fields": ["shard_dir", "shard_count"],
        "optional_fields": ["vocab_size", "num_layers", "hidden_size", "dtype"],
        "example_shard_dir": "models/shards/mymodel/",
        "latency": "< 100ms first token (GPU)",
        "use_when": "Expert shards from scxqdds pipeline, INT8 quantized inference"
      },
      "fetch_oss": {
        "description": "Pull GGUF weights from HuggingFace on first run. Cached locally after download.",
        "runtime_dep": "pip install huggingface_hub llama-cpp-python",
        "required_fields": ["hf_repo", "hf_file", "local_cache"],
        "optional_fields": ["vocab_size", "num_layers", "hidden_size", "quantization", "license"],
        "first_run": "Downloads 2-8GB — expect delay",
        "use_when": "No local weights yet, want MIT/Apache OSS model"
      },
      "api_openai": {
        "description": "OpenAI API stream (gpt-4o, gpt-4.1, gpt-4o-mini, etc.)",
        "runtime_dep": "pip install openai",
        "required_fields": ["model", "env_key"],
        "optional_fields": ["api_base", "max_tokens", "temperature"],
        "default_model": "gpt-4o",
        "env_key": "OPENAI_API_KEY",
        "use_when": "OpenAI API access, no local GPU"
      },
      "api_anthropic": {
        "description": "Anthropic API stream (claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5).",
        "runtime_dep": "pip install anthropic",
        "required_fields": ["model", "env_key"],
        "optional_fields": ["max_tokens"],
        "default_model": "claude-sonnet-4-6",
        "env_key": "ANTHROPIC_API_KEY",
        "model_guide": {
          "claude-opus-4-6": "Deep reasoning, PATTERN/META folds",
          "claude-sonnet-4-6": "Best balance — default for most micronauts",
          "claude-haiku-4-5-20251001": "High-frequency, low-cost — DATA/STORAGE folds"
        },
        "use_when": "Anthropic API access, quality-first"
      },
      "api_ollama": {
        "description": "Local Ollama server (ollama serve). OpenAI-compatible API.",
        "runtime_dep": "ollama running on localhost:11434",
        "required_fields": ["model"],
        "optional_fields": ["api_base"],
        "default_api_base": "http://localhost:11434/v1",
        "popular_models": ["phi3:mini", "llama3.1:8b", "qwen2.5:7b", "deepseek-r1:7b", "mistral:7b"],
        "use_when": "Already running Ollama, local inference without llama-cpp-python setup"
      },
      "api_custom": {
        "description": "Any OpenAI-compatible endpoint (LM Studio, vLLM, text-generation-webui, llama.cpp server).",
        "runtime_dep": "pip install openai",
        "required_fields": ["model", "api_base"],
        "optional_fields": ["env_key"],
        "use_when": "Custom inference server, private deployment"
      }
    },
    "selection_guide": {
      "lowest_latency": ["local_gguf", "local_scxqdds"],
      "offline_required": ["local_gguf", "local_scxqdds", "fetch_oss"],
      "no_local_setup": ["api_anthropic", "api_openai"],
      "already_have_ollama": ["api_ollama"],
      "custom_server": ["api_custom"],
      "best_quality": "api_anthropic (claude-opus-4-6)",
      "best_speed_quality": "api_anthropic (claude-sonnet-4-6) or api_openai (gpt-4o)",
      "free_oss_mit": "fetch_oss with microsoft/Phi-3-mini-4k-instruct or lmstudio-community/DeepSeek-R1-Distill-Qwen-7B-GGUF"
    }
  },

