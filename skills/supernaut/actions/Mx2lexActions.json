{
  "class": "Mx2lexActions",
  "methods": {
    "compile": {
      "params": ["grammar"],
      "body": [
        {"op": "exec", "cmd": "mx2lex_compile.exe \"$grammar\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "mx2lex.compile", "grammar": "$grammar", "result": "$out"}}
      ]
    },
    "oracle": {
      "params": ["dfa"],
      "body": [
        {"op": "exec", "cmd": "mx2lex_oracle.exe \"$dfa\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "mx2lex.oracle", "dfa": "$dfa", "result": "$out"}}
      ]
    },
    "vectorRun": {
      "params": ["dfa", "input"],
      "body": [
        {"op": "exec", "cmd": "mx2lex_oracle.exe \"$dfa\" --vector \"$input\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "mx2lex.vector_run", "dfa": "$dfa", "result": "$out"}}
      ]
    }
  }
}