{
  "version": "1.0",
  "domain": "cloudflare-deploy",
  "source_skill": "cloudflare-deploy",
  "actions": [
    {
      "id": "deployWorker",
      "intent": "cf_deploy_worker",
      "name": "Deploy Worker",
      "description": "Deploy a Cloudflare Worker script via wrangler",
      "trigger": ["deploy worker", "cloudflare worker deploy", "wrangler deploy", "publish worker"],
      "handler": "CloudflareDeployActions.deploy_worker"
    },
    {
      "id": "deployPages",
      "intent": "cf_deploy_pages",
      "name": "Deploy Pages",
      "description": "Deploy a static site or SSR app to Cloudflare Pages",
      "trigger": ["deploy pages", "cloudflare pages deploy", "publish pages site", "cf pages deploy"],
      "handler": "CloudflareDeployActions.deploy_pages"
    },
    {
      "id": "publishKv",
      "intent": "cf_publish_kv",
      "name": "Publish KV",
      "description": "Write key-value pairs to a Cloudflare KV namespace",
      "trigger": ["publish kv", "cloudflare kv write", "cf kv put", "kv namespace write"],
      "handler": "CloudflareDeployActions.publish_kv"
    },
    {
      "id": "uploadR2",
      "intent": "cf_upload_r2",
      "name": "Upload R2",
      "description": "Upload objects or files to a Cloudflare R2 bucket",
      "trigger": ["upload r2", "cloudflare r2 upload", "cf r2 put", "r2 bucket upload"],
      "handler": "CloudflareDeployActions.upload_r2"
    },
    {
      "id": "migrateD1",
      "intent": "cf_migrate_d1",
      "name": "Migrate D1",
      "description": "Run migrations against a Cloudflare D1 SQL database",
      "trigger": ["migrate d1", "cloudflare d1 migrate", "d1 sql migration", "cf d1 apply"],
      "handler": "CloudflareDeployActions.migrate_d1"
    },
    {
      "id": "listDeployments",
      "intent": "cf_list_deployments",
      "name": "List Deployments",
      "description": "List recent Cloudflare deployments for Workers and Pages projects",
      "trigger": ["list deployments", "cloudflare deployment list", "cf deployment history"],
      "handler": "CloudflareDeployActions.list_deployments"
    }
  ]
}
