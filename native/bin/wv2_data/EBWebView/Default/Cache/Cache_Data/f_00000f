  <script>
    // Minimal SCX stub (UTF-8 base64 decode) for any inline content if needed later
    const SCX = {
      decodeUtf8Base64(b64){
        try { return decodeURIComponent(escape(atob(b64 || ""))); }
        catch(e){ return "SCX-DECODE-ERR: " + e.message; }
