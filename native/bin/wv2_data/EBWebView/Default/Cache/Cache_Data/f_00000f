      renderDebugger(root){
        root.style.cssText="padding:0;overflow:hidden;height:100%;display:flex;flex-direction:column;";

        // ── CONTROL BAR ────────────────────────────────────────────────────────
        const ctrlBar=document.createElement("div");
        ctrlBar.style.cssText="display:flex;align-items:center;gap:8px;padding:7px 12px;"+
          "background:#000b16;border-bottom:1px solid rgba(0,255,255,.2);flex-shrink:0;";
        const mkBtn=(txt)=>{
          const b=document.createElement("button");b.textContent=txt;
          b.style.cssText="padding:4px 12px;background:rgba(0,255,255,.08);border:1px solid #0ff;"+
            "color:#0ff;font-family:Orbitron,monospace;font-size:11px;cursor:pointer;border-radius:4px;letter-spacing:1px;";
          b.onmouseenter=()=>b.style.background="rgba(0,255,255,.22)";
          b.onmouseleave=()=>b.style.background="rgba(0,255,255,.08)";
          return b;
        };
        const stepBtn=mkBtn("STEP"),runBtn=mkBtn("RUN"),pauseBtn=mkBtn("PAUSE");
        stepBtn.dataset.kuhulClick="⟁ DBG_STEP [Xul]";
        runBtn.dataset.kuhulClick="⟁ DBG_RUN [Xul]";
        pauseBtn.dataset.kuhulClick="⟁ DBG_PAUSE [Xul]";
        const fusedBtn=mkBtn("FUSED: OFF");fusedBtn.style.color="#ff88ff";fusedBtn.style.borderColor="#ff88ff";
        fusedBtn.dataset.kuhulClick="⟁ DBG_FUSED [Xul]";
        const modeEl=document.createElement("span");
        modeEl.style.cssText="font-size:10px;letter-spacing:2px;color:#ffdc00;margin-left:6px;";
        modeEl.textContent="MODE: RUN";
        const spacer=document.createElement("div");spacer.style.flex="1";
        const perfEl=document.createElement("div");
        perfEl.style.cssText="display:flex;gap:12px;font-size:10px;font-family:'Courier New',monospace;color:rgba(0,255,255,.55);";
        perfEl.innerHTML=`<span>GPU <b id="pb-gpu" style="color:#0ff">—</b>ms</span>`+
          `<span>Disk <b id="pb-disk" style="color:#0ff">—</b>ms</span>`+
          `<span>IO <b id="pb-io" style="color:#0f8">—</b>%</span>`+
          `<span>Thr <b id="pb-thr" style="color:#0ff">—</b>h/s</span>`+
          `<span>Err <b id="pb-err" style="color:#ff0">—</b></span>`;
        ctrlBar.append(stepBtn,runBtn,pauseBtn,fusedBtn,modeEl,spacer,perfEl);

        // DBG controller object
        let demoFused=false;
        window.dbg={mode:"run",
          step(){ this.mode="step"; modeEl.textContent="MODE: STEP"; },
          run(){  this.mode="run";  modeEl.textContent="MODE: RUN";  },
          pause(){ this.mode="pause"; modeEl.textContent="MODE: PAUSE"; }
        };
        stepBtn.onclick=()=>window.dbg.step();
        runBtn.onclick= ()=>window.dbg.run();
        pauseBtn.onclick=()=>window.dbg.pause();
        fusedBtn.onclick=()=>{
          demoFused=!demoFused;
          fusedBtn.textContent="FUSED: "+(demoFused?"ON":"OFF");
          fusedBtn.style.background=demoFused?"rgba(255,0,255,.18)":"rgba(0,255,255,.08)";
        };

        // ── MAIN 3-COL LAYOUT ──────────────────────────────────────────────────
        const layout=document.createElement("div");
        layout.style.cssText="display:grid;grid-template-columns:200px 1fr 1fr;gap:8px;"+
          "flex:1;min-height:0;padding:8px;overflow:hidden;";

        // ═══════════════════════════════════════════════
        // COL 1: Tile Flow Canvas
        // ═══════════════════════════════════════════════
        const col1=document.createElement("div");
        col1.className="dbg-panel";
        col1.style.cssText="overflow:hidden;display:flex;flex-direction:column;";
        col1.innerHTML=`<div class="dbg-label">TILE FLOW</div>`;
        const flowCvs=document.createElement("canvas");
        flowCvs.width=200;flowCvs.height=280;
        flowCvs.style.cssText="width:100%;flex:1;";
        col1.appendChild(flowCvs);
        const fc=flowCvs.getContext("2d");

        const slotState={A:{state:"idle",tile:""},B:{state:"idle",tile:""},C:{state:"idle",tile:""}};
        const SY={A:50,B:140,C:230}; // y-centers for slots
        const SX=100;
        const SCOL={compute:"#00ff50",load:"#ffdc00",prefetch:"#0096ff",idle:"rgba(0,255,255,.18)"};
        const tileAnims=[];

        function setSlot(n,state,tile){
          if(!slotState[n]) return;
          slotState[n].state=state; slotState[n].tile=tile||"";
        }

        function drawFlowCanvas(){
          const W=flowCvs.width,H=flowCvs.height;
          fc.fillStyle="#000a14"; fc.fillRect(0,0,W,H);
          // flow lines
          fc.setLineDash([4,6]); fc.strokeStyle="rgba(0,255,255,.1)"; fc.lineWidth=1.5;
          ["A","B"].forEach((n,i)=>{
            const y0=SY[n]+28, y1=(i===0?SY.B:SY.C)-28;
            fc.beginPath(); fc.moveTo(SX,y0); fc.lineTo(SX,y1); fc.stroke();
          });
          // GPU label top, Disk label bottom
          fc.setLineDash([3,5]); fc.strokeStyle="rgba(0,255,255,.08)";
          fc.beginPath(); fc.moveTo(SX,16); fc.lineTo(SX,SY.A-28); fc.stroke();
          fc.beginPath(); fc.moveTo(SX,H-16); fc.lineTo(SX,SY.C+28); fc.stroke();
          fc.setLineDash([]);
          fc.fillStyle="rgba(0,255,255,.35)"; fc.font="8px Orbitron,monospace"; fc.textAlign="center";
          fc.fillText("GPU",SX,12); fc.fillText("DISK",SX,H-4);

          // Draw slots
          for(const n of ["A","B","C"]){
            const s=slotState[n], col=SCOL[s.state]||SCOL.idle;
            const x=SX-60, y=SY[n]-24, w=120, h=48;
            fc.shadowColor=col; fc.shadowBlur=s.state==="idle"?0:14;
            fc.fillStyle=col.replace("255,","255,").replace("18)","05)");
            // simple rect fill (roundRect not always available)
            fc.fillRect(x,y,w,h);
            fc.shadowBlur=0;
            fc.strokeStyle=col; fc.lineWidth=1.5;
            fc.strokeRect(x+.75,y+.75,w-1.5,h-1.5);
            fc.fillStyle=col; fc.font="bold 12px Orbitron,monospace"; fc.textAlign="left";
            fc.fillText(n,x+8,y+18);
            fc.fillStyle="rgba(255,255,255,.45)"; fc.font="9px 'Courier New',monospace";
            fc.fillText(s.state.toUpperCase(),x+26,y+18);
            if(s.tile){ fc.fillStyle="rgba(0,255,255,.55)"; fc.fillText(s.tile,x+8,y+36); }
          }

          // Animate moving tiles
          const now=performance.now();
          for(let i=tileAnims.length-1;i>=0;i--){
            const a=tileAnims[i], p=Math.min(1,(now-a.t0)/280);
            const x=a.x0+(a.x1-a.x0)*p, y=a.y0+(a.y1-a.y0)*p;
            fc.shadowColor=a.col; fc.shadowBlur=10;
            fc.fillStyle=a.col; fc.beginPath(); fc.arc(x,y,7,0,Math.PI*2); fc.fill();
            fc.shadowBlur=0;
            fc.fillStyle="#000"; fc.font="6px 'Courier New',monospace"; fc.textAlign="center";
            fc.fillText(a.lbl||"",x,y+2);
            if(p>=1) tileAnims.splice(i,1);
          }
          fc.textAlign="left";
        }

        const ENDPOS={A:{x:SX,y:SY.A},B:{x:SX,y:SY.B},C:{x:SX,y:SY.C},
                      disk:{x:SX,y:flowCvs.height-8},gpu:{x:SX,y:8}};
        window.NotifyTileMove=function(from,to,lbl){
          const f=ENDPOS[from]||ENDPOS.disk, t=ENDPOS[to]||ENDPOS.gpu;
          tileAnims.push({x0:f.x,y0:f.y,x1:t.x,y1:t.y,t0:performance.now(),lbl:lbl||"T",col:"#ffdc00"});
        };

        // ═══════════════════════════════════════════════
        // COL 2: Dispatch waveform + Attention matrix + Error heatmap
        // ═══════════════════════════════════════════════
        const col2=document.createElement("div");
        col2.className="dbg-panel";
        col2.style.cssText="overflow:hidden;display:flex;flex-direction:column;gap:5px;";
        col2.innerHTML=`<div class="dbg-label">DISPATCH + ATTENTION</div>`;

        // Waveform
        const wvCvs=document.createElement("canvas");
        wvCvs.width=400;wvCvs.height=48;
        wvCvs.style.cssText="width:100%;background:#000;border-radius:4px;flex-shrink:0;";
        col2.appendChild(wvCvs);
        const wvCtx=wvCvs.getContext("2d");
        const wvBuf=new Array(400).fill(0);
        let wvActivity=0;

        // Dispatch bar
        const barBg=document.createElement("div");
        barBg.style.cssText="background:#020c14;border:1px solid rgba(0,255,255,.18);border-radius:4px;height:18px;overflow:hidden;flex-shrink:0;";
        const barFill=document.createElement("div");
        barFill.style.cssText="height:100%;width:0%;background:linear-gradient(90deg,#00ffaa,#00ccff);transition:width .08s;";
        barBg.appendChild(barFill); col2.appendChild(barBg);

        // Attention matrix 64×64 @ 4px/cell = 256×256
        const attnLbl=document.createElement("div");
        attnLbl.style.cssText="font-size:9px;color:rgba(0,255,255,.4);letter-spacing:1px;flex-shrink:0;";
        attnLbl.textContent="ATTENTION MATRIX [64\xD764]";
        col2.appendChild(attnLbl);

        const attnCvs=document.createElement("canvas");
        attnCvs.width=256;attnCvs.height=256;
        attnCvs.style.cssText="width:100%;border:1px solid rgba(0,255,255,.12);border-radius:4px;image-rendering:pixelated;flex:1;min-height:0;";
        col2.appendChild(attnCvs);
        const attnCtx=attnCvs.getContext("2d");
        const attnImg=attnCtx.createImageData(256,256);

        function drawAttention(mat){
          const d=attnImg.data;
          for(let r=0;r<64;r++) for(let c=0;c<64;c++){
            const v=Math.max(0,Math.min(1,mat[r*64+c]||0));
            for(let py=0;py<4;py++) for(let px=0;px<4;px++){
              const pi=((r*4+py)*256+(c*4+px))*4;
              d[pi]=0; d[pi+1]=(v*255)|0; d[pi+2]=(v*255)|0; d[pi+3]=255;
            }
          }
          attnCtx.putImageData(attnImg,0,0);
        }
        window.DrawAttention=function(arr){ drawAttention(arr); };

        // Error heatmap strip
        const errLbl=document.createElement("div");
        errLbl.style.cssText="font-size:9px;color:rgba(255,140,0,.5);letter-spacing:1px;flex-shrink:0;";
        errLbl.textContent="ERROR HEATMAP (64 recent ops)";
        col2.appendChild(errLbl);

        const errCvs=document.createElement("canvas");
        errCvs.width=256;errCvs.height=20;
        errCvs.style.cssText="width:100%;border:1px solid rgba(255,80,0,.18);border-radius:4px;image-rendering:pixelated;flex-shrink:0;";
        col2.appendChild(errCvs);
        const errCtx=errCvs.getContext("2d");
        const errBuf=new Array(64).fill(0);

        function pushErr(v){ errBuf.push(v); if(errBuf.length>64) errBuf.shift(); }
        function drawErrMap(){
          const img=errCtx.createImageData(256,20), d=img.data;
          const mx=Math.max(...errBuf,1e-10);
          for(let i=0;i<64;i++){
            const v=Math.min(1,errBuf[i]/mx);
            const r=(v*220)|0, g=((1-v)*60)|0;
            for(let y=0;y<20;y++) for(let x=0;x<4;x++){
              const pi=(y*256+i*4+x)*4;
              d[pi]=r; d[pi+1]=g; d[pi+2]=0; d[pi+3]=255;
            }
          }
          errCtx.putImageData(img,0,0);
        }

        // ═══════════════════════════════════════════════
        // COL 3: Op trace + SCXQ2 timeline
        // ═══════════════════════════════════════════════
        const col3=document.createElement("div");
        col3.className="dbg-panel";
        col3.style.cssText="overflow:hidden;display:flex;flex-direction:column;gap:5px;";
        col3.innerHTML=`<div class="dbg-label">SCXQ2 OP TRACE</div>`;

        const traceLog=document.createElement("div");
        traceLog.className="op-trace";
        traceLog.style.cssText="flex:1;min-height:0;overflow-y:auto;";
        col3.appendChild(traceLog);

        const tlLbl=document.createElement("div");
        tlLbl.style.cssText="font-size:9px;color:rgba(0,255,255,.4);letter-spacing:1px;flex-shrink:0;";
        tlLbl.textContent="TIMELINE";
        col3.appendChild(tlLbl);

        const tlCvs=document.createElement("canvas");
        tlCvs.width=400;tlCvs.height=36;
        tlCvs.style.cssText="width:100%;border:1px solid rgba(0,255,255,.1);border-radius:4px;background:#000;flex-shrink:0;";
        col3.appendChild(tlCvs);
        const tlCtx=tlCvs.getContext("2d");
        const tlBuf=[];
        const OPCOL={LOAD_Q:"#4499ff",LOAD_K:"#44aaff",LOAD_V:"#44ccff",
          QK_DOT:"#ff9944",SOFTMAX:"#ffcc44",PV_MUL:"#44ffaa",
          ATTN_FUSED:"#ff44ff",STORE:"#aaffaa",LAYER_FOLD:"#ffff44"};

        function pushTimeline(op,ms){
          tlBuf.push({op,ms:ms||30,col:OPCOL[op]||"#0ff"});
          if(tlBuf.length>48) tlBuf.shift();
        }
        function drawTimeline(){
          const W=tlCvs.width,H=tlCvs.height;
          tlCtx.fillStyle="#000"; tlCtx.fillRect(0,0,W,H);
          if(!tlBuf.length) return;
          const total=tlBuf.reduce((s,b)=>s+b.ms,0)||1;
          let x=0;
          for(const b of tlBuf){
            const w=Math.max(3,(b.ms/total)*W);
            tlCtx.fillStyle=b.col; tlCtx.fillRect(x,3,w-1,H-6);
            if(w>16){ tlCtx.fillStyle="#000"; tlCtx.font="7px 'Courier New',monospace";
              tlCtx.fillText(b.op.slice(0,5),x+2,H/2+3); }
            x+=w;
          }
        }

        function emitTrace(opCode,detail,err){
          const t=new Date().toISOString().substr(11,8);
          const fused=opCode==="ATTN_FUSED";
          const line=document.createElement("div"); line.className="op-line";
          if(fused) line.style.cssText="background:rgba(255,0,255,.07);border-bottom:1px solid rgba(255,0,255,.12);";
          line.innerHTML=`<span class="op-ts">${t}</span>`+
            `<span class="op-code" style="${fused?"color:#ff55ff":""}">${opCode}${fused?" \u27C1":""}</span>`+
            `<span class="op-detail">${detail||""}</span>`+
            (err!=null?`<span class="op-err">err=${typeof err==="number"?err.toExponential(2):err}</span>`:"");
          traceLog.appendChild(line);
          if(traceLog.children.length>300) traceLog.removeChild(traceLog.firstChild);
          traceLog.scrollTop=traceLog.scrollHeight;
        }

        // ── Window bridge hooks ────────────────────────────────────────────────
        window.GPU_ACTIVITY=function(v){
          wvActivity=Math.max(0,Math.min(1,v));
          barFill.style.width=(wvActivity*100)+"%";
        };
        window.EmitToUI=function(opStr){
          const m=opStr.match(/^(\S+)\s*(.*?)(?:\s+err=(\S+?))?(?:\s+ms=(\S+?))?$/);
          if(m){
            const err=m[3]!=null?parseFloat(m[3]):null;
            const ms=m[4]!=null?parseFloat(m[4]):30;
            emitTrace(m[1],m[2]||"",err);
            if(err!=null) pushErr(err);
            pushTimeline(m[1],ms);
          } else emitTrace(opStr,"",null);
        };

        // ASX_SLOTS polling watcher
        const slotWatcher=setInterval(()=>{
          const sl=window.ASX_SLOTS;
          if(!sl||typeof sl!=="object") return;
          ["A","B","C"].forEach(n=>{ if(sl[n]) setSlot(n,sl[n],sl.tiles?.[n]||""); });
          const s=sl.stats||{};
          const $=id=>document.getElementById(id);
          const fmt=(v,fn)=>v!=null?fn(v):"—";
          if($("pb-gpu"))  $("pb-gpu").textContent=fmt(s.gpu_ms,v=>v.toFixed(1));
          if($("pb-disk")) $("pb-disk").textContent=fmt(s.disk_ms,v=>v.toFixed(1));
          if($("pb-thr"))  $("pb-thr").textContent=fmt(s.thr_hps,v=>v.toFixed(1));
          if($("pb-err"))  $("pb-err").textContent=fmt(s.max_err,v=>v.toExponential(2));
          if($("pb-io") && s.gpu_ms!=null && s.disk_ms!=null){
            const total=s.gpu_ms+s.disk_ms;
            $("pb-io").textContent=total>0?((s.gpu_ms/total)*100).toFixed(0):"—";
          }
        },80);

        // ── Demo ticker ────────────────────────────────────────────────────────
        const DEMO_OPS=["LOAD_Q","LOAD_K","LOAD_V","QK_DOT","SOFTMAX","PV_MUL","STORE","LAYER_FOLD"];
        const DEMO_CYCLE=[
          {A:"idle",  B:"load",   C:"idle",   mv:["disk","C"]},
          {A:"idle",  B:"load",   C:"prefetch",mv:["C","B"]},
          {A:"compute",B:"idle",  C:"load",   mv:["B","A"]},
          {A:"compute",B:"prefetch",C:"idle", mv:["A","gpu"]},
          {A:"idle",  B:"compute",C:"load",   mv:["C","B"]},
        ];
        let ph=0,dHead=0,dLayer=0;
        const demoAttn=new Float32Array(4096);

        const demoTick=setInterval(()=>{
          if(window.ASX_SLOTS) return;
          if(window.dbg&&window.dbg.mode==="pause") return;
          const cyc=DEMO_CYCLE[ph%DEMO_CYCLE.length];
          ["A","B","C"].forEach(n=>setSlot(n,cyc[n]||"idle",
            cyc[n]==="idle"?"":("h"+dHead+"/t"+(ph%16))));
          if(cyc.mv) window.NotifyTileMove(cyc.mv[0],cyc.mv[1],"T"+(ph%16));
          const computing=cyc.A==="compute"||cyc.B==="compute";
          const act=computing?0.6+Math.random()*0.4:Math.random()*0.1;
          window.GPU_ACTIVITY(act);
          if(computing){
            // Synthetic causal attention
            for(let r=0;r<64;r++){
              let sum=0;
              for(let c=0;c<64;c++){
                const v=c<=r?Math.exp(-(r-c)*0.12+Math.random()*0.25):0;
                demoAttn[r*64+c]=v; sum+=v;
              }
              if(sum>0) for(let c=0;c<64;c++) demoAttn[r*64+c]/=sum;
            }
            drawAttention(demoAttn);
            const op=demoFused?"ATTN_FUSED":DEMO_OPS[ph%DEMO_OPS.length];
            const err=1.49e-8+(Math.random()-0.5)*2e-9;
            const ms=28+Math.random()*10;
            window.EmitToUI(`${op} layer=${dLayer} head=${dHead} err=${err.toExponential(3)} ms=${ms.toFixed(1)}`);
            if(window.dbg&&window.dbg.mode==="step") window.dbg.pause();
            dHead=(dHead+1)%16;
            if(dHead===0) dLayer=(dLayer+1)%24;
          }
          ph++;
        },420);

        // ── Render loop ────────────────────────────────────────────────────────
        const wvLoop=setInterval(()=>{
          wvBuf.push(wvActivity); if(wvBuf.length>400) wvBuf.shift();
          // Waveform
          const W=wvCvs.width,H=wvCvs.height;
          wvCtx.fillStyle="#000"; wvCtx.fillRect(0,0,W,H);
          wvCtx.beginPath(); wvCtx.strokeStyle="#00ffaa"; wvCtx.lineWidth=1.5;
          for(let i=0;i<wvBuf.length;i++){
            const x=i,y=H-wvBuf[i]*(H-4)-2;
            i===0?wvCtx.moveTo(x,y):wvCtx.lineTo(x,y);
          }
          wvCtx.stroke();
          wvCtx.strokeStyle="rgba(0,255,255,.06)"; wvCtx.lineWidth=1;
          for(let y=0;y<H;y+=12){wvCtx.beginPath();wvCtx.moveTo(0,y);wvCtx.lineTo(W,y);wvCtx.stroke();}
          // Flow canvas + heatmap + timeline
          drawFlowCanvas(); drawErrMap(); drawTimeline();
        },50);

        // ── Assemble ───────────────────────────────────────────────────────────
        layout.append(col1,col2,col3);
        root.append(ctrlBar,layout);

        // ── Cleanup ────────────────────────────────────────────────────────────
        const observer=new MutationObserver(()=>{
          if(!root.isConnected){
            clearInterval(demoTick);clearInterval(wvLoop);clearInterval(slotWatcher);
            delete window.GPU_ACTIVITY;delete window.EmitToUI;
            delete window.DrawAttention;delete window.NotifyTileMove;delete window.dbg;
            observer.disconnect();
          }
        });
        observer.observe(root,{childList:true});
      }

      // ════════════════════════════════════════════════════════════════════════
      // SVG-3D RUNTIME — K'uhul vector geometry, no CUDA
      // ════════════════════════════════════════════════════════════════════════
      renderSVG3D(root){
        root.style.cssText="padding:0;overflow:hidden;height:100%;display:flex;flex-direction:column;background:#00050f;";

        // Banner
        const banner=document.createElement("div");
        banner.style.cssText="padding:5px 14px;background:#000b16;border-bottom:1px solid rgba(22,242,170,.2);"+
