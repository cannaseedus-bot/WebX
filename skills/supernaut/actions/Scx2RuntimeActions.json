{
  "class": "Scx2RuntimeActions",
  "methods": {
    "smoke": {
      "params": ["bytecode"],
      "body": [
        {"op": "set", "var": "bc", "value": "$bytecode"},
        {"op": "exec", "cmd": "scx2_runtime_smoke.exe \"$bytecode\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "scx2-runtime.smoke", "bytecode": "$bytecode", "result": "$out"}}
      ]
    }
  }
}