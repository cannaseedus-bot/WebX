          const tbl=document.createElement("div");
          tbl.style.cssText="display:grid;grid-template-columns:1fr auto auto auto;gap:1px;background:#1e1e30;border:1px solid #1e1e30;border-radius:6px;overflow:hidden;font-family:monospace;font-size:10px;";
          ["RESOURCE ID","TYPE","ENCODING","SIZE"].forEach(h=>{
