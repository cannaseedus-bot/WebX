        cvs.width=640;cvs.height=220;
        const ctx=cvs.getContext("2d");
        const W=cvs.width,H=cvs.height;
        const state={t:0,last:performance.now(),ship:{x:W/2},en:[],dx:1,bul:[],auto:true,cd:0,score:0};
        for(let r=0;r<3;r++) for(let c=0;c<10;c++) state.en.push({x:60+c*45,y:50+r*24});
        (function step(now){
          requestAnimationFrame(step);
          const dt=Math.min(.033,(now-(state.last||now))/1000);
          state.last=now;state.t+=dt;state.cd-=dt;
          let edge=false;
          state.en.forEach(e=>{
            e.x+=state.dx*40*dt;
            if(e.x<20||e.x>W-20) edge=true;
          });
          if(edge){ state.dx*=-1; state.en.forEach(e=>e.y+=6); }
          if(state.auto && state.cd<=0){
            state.bul.push({x:state.ship.x,y:H-30,v:-260});
            state.cd=.22;
          }
          state.bul.forEach(b=>b.y+=b.v*dt);
          for(const b of state.bul){
            for(const e of state.en){
              if(Math.abs(b.x-e.x)<10 && Math.abs(b.y-e.y)<10){
                b.hit=true;e.hit=true;state.score+=25;
              }
            }
          }
          state.en=state.en.filter(e=>!e.hit);
          state.bul=state.bul.filter(b=>!b.hit && b.y>-40);
          ctx.fillStyle="#01070d";ctx.fillRect(0,0,W,H);
          ctx.fillStyle="#7fd3ff";
          ctx.fillRect(state.ship.x-12,H-28,24,18);
          ctx.fillStyle="#ffcc7a";
          state.en.forEach(e=>ctx.fillRect(e.x-8,e.y-6,16,12));
          ctx.fillStyle="#fff";
          state.bul.forEach(b=>ctx.fillRect(b.x-2,b.y-6,4,12));
