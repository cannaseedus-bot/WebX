{
  "class": "PipxCompilerActions",
  "methods": {
    "run": {
      "params": ["plan", "output"],
      "body": [
        {"op": "exec", "cmd": "pipx_compiler.exe \"$plan\" --out \"$output\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "pipx-compiler.run", "plan": "$plan", "output": "$output", "result": "$out"}}
      ]
    }
  }
}