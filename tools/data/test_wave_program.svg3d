<?xml version="1.0" encoding="UTF-8"?>
<svg3d version="1.0">

  <!-- Metadata -->
  <meta 
    name="wave_attractor_game"
    author="sh-wave-lattice"
    sh_l="2"
    description="Spatial programming: inject waves, propagate, match attractor"
  />

  <!-- Physics Domain -->
  <domain
    type="wave"
    decay="0.99"
    coupling="0.05"
    energy_injection="0.005"
    propagation="uniform"
  />

  <!-- Compute Topology -->
  <graph>
    <!-- Injection source -->
    <node 
      id="inject_band1" 
      pos="0,0,1" 
      type="inject"
      band="1"
      amplitude="1.0"
      phase="0.0"
    />

    <!-- Propagation step -->
    <node 
      id="propagate_5" 
      pos="0,0,0.5" 
      type="propagate"
      steps="5"
    />

    <!-- Pattern storage (attractor learning) -->
    <node 
      id="store_pattern" 
      pos="0,0,0" 
      type="memory"
    />

    <!-- Probe output -->
    <node 
      id="read_result" 
      pos="1,0,0" 
      type="probe"
      band="1"
    />

    <!-- Execution edges (define data flow) -->
    <edge from="inject_band1" to="propagate_5" weight="1.0"/>
    <edge from="propagate_5" to="store_pattern" weight="1.0"/>
    <edge from="store_pattern" to="read_result" weight="1.0"/>
  </graph>

  <!-- Program Execution -->
  <program>
    <!-- Inject signal into band 1 at amplitude 1.0 -->
    <inject node="inject_band1" band="1" amplitude="1.0" phase="0.0"/>

    <!-- Propagate wave through field for 5 steps -->
    <propagate steps="5"/>

    <!-- Store current field state as pattern (attractor learning) -->
    <memory store="true"/>

    <!-- Probe band 1 to read result -->
    <read node="read_result" band="1"/>

  </program>

</svg3d>
