{
  "class": "AsxVerifierActions",
  "methods": {
    "verify": {
      "params": ["envelope_dir"],
      "body": [
        {"op": "set", "var": "req", "value": {"envelope": "$envelope_dir", "mode": "verify"}},
        {"op": "exec", "cmd": "asx_verifier.exe \"$envelope_dir\"", "result": "raw_out"},
        {"op": "json", "value": {"ok": true, "execution": "asx-verifier.verify", "envelope": "$envelope_dir", "result": "$raw_out"}}
      ]
    },
    "verifyBad": {
      "params": ["envelope_dir"],
      "body": [
        {"op": "set", "var": "req", "value": {"envelope": "$envelope_dir", "mode": "negative"}},
        {"op": "exec", "cmd": "asx_verifier.exe \"$envelope_dir\" --expect-fail", "result": "raw_out"},
        {"op": "json", "value": {"ok": true, "execution": "asx-verifier.verify_bad", "envelope": "$envelope_dir", "result": "$raw_out"}}
      ]
    }
  }
}