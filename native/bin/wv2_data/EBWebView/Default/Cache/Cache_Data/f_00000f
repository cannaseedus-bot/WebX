              detail.appendChild(depRow);
            }

            // install log
            if(installLog.length){
              detail.appendChild(lbl("INSTALL LOG"));
              detail.appendChild(pre(installLog.join('\n'),'#aaa'));
            }
          }

          buildList();
          renderDetail();
        }

        // ── PLUGIN INDEX tab ───────────────────────────────────────────────
        function renderIndex(){
          content.innerHTML="";
          content.style.flexDirection="column";
          const wrap=document.createElement("div");
          wrap.style.cssText="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px;";
