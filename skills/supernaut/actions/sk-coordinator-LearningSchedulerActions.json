{
  "class": "LearningSchedulerActions",
  "methods": {
    "schedule_learning": {
      "params": ["topic", "timeframe", "priority"],
      "body": [
        {
          "op": "set",
          "var": "schedule",
          "value": {
            "topic": "$topic",
            "timeframe": "$timeframe",
            "priority": "$priority",
            "status": "scheduled"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "scheduler": "$schedule"
          }
        }
      ]
    }
  }
}
