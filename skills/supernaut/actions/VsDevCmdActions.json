{
  "class": "VsDevCmdActions",
  "methods": {
    "setup_env": {
      "params": ["arch", "hostArch"],
      "body": [
        {
          "op": "set",
          "var": "envCtx",
          "value": {
            "arch": "$arch",
            "hostArch": "$hostArch",
            "vsDevCmdBat": "C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\Common7\\Tools\\VsDevCmd.bat",
            "vsMSBuildCmdBat": "C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\Common7\\Tools\\VsMSBuildCmd.bat",
            "launchDevShell": "C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\Common7\\Tools\\Launch-VsDevShell.ps1",
            "devShellDll": "C:\\Program Files (x86)\\Microsoft Visual Studio\\2022\\BuildTools\\Common7\\Tools\\Microsoft.VisualStudio.DevShell.dll",
            "version": "17.0.36906.2"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "vsdevcmd.setup_env",
              "mode": "deterministic"
            },
            "env": "$envCtx",
            "invocation": "& \"$envCtx.vsDevCmdBat\" -arch=$arch -host_arch=$hostArch"
          }
        }
      ]
    },
    "debug_env": {
      "params": ["missingVar"],
      "body": [
        {
          "op": "set",
          "var": "diagnosis",
          "value": {
            "missingVar": "$missingVar",
            "suggestions": [
              "Run VsDevCmd.bat before invoking cl.exe or msbuild",
              "For PowerShell: use Launch-VsDevShell.ps1 or Import-Module Microsoft.VisualStudio.DevShell.dll",
              "Check -arch= and -host_arch= match your target (x64, x86, arm64)",
              "Verify VS 2022 BuildTools is fully installed with C++ workload"
            ]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "vsdevcmd.debug_env",
              "mode": "deterministic"
            },
            "diagnosis": "$diagnosis"
          }
        }
      ]
    }
  }
}
