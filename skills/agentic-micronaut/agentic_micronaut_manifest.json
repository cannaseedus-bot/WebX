{
  "name": "agentic-micronaut",
  "version": "1.0.0",
  "description": "Agentic Micronaut deterministic runtime builder with skill projection and fleet agent wiring",
  "runtime": "xcfe",
  "routes": {
    "arbitrate": {
      "action": "arbitrate",
      "skill_intent": "agentic.arbitrate",
      "description": "Arbitrate between multiple agent decisions",
      "method": "POST",
      "path": "/skill/agentic/arbitrate"
    },
    "project_skill": {
      "action": "project_skill",
      "skill_intent": "agentic.project_skill",
      "description": "Project a skill into Micronaut-style runtime format",
      "method": "POST",
      "path": "/skill/agentic/project"
    },
    "resolve_agent": {
      "action": "resolve_agent",
      "skill_intent": "agentic.resolve_agent",
      "description": "Resolve agent configuration and dependencies",
      "method": "POST",
      "path": "/skill/agentic/resolve"
    },
    "list_registry": {
      "action": "list_registry",
      "skill_intent": "agentic.list_registry",
      "description": "List available models and skills in registry",
      "method": "GET",
      "path": "/skill/agentic/registry"
    },
    "pack_shard": {
      "action": "pack_shard",
      "skill_intent": "agentic.pack_shard",
      "description": "Pack agent shard for deployment",
      "method": "POST",
      "path": "/skill/agentic/pack"
    },
    "wire_fleet_agent": {
      "action": "wire_fleet_agent",
      "skill_intent": "agentic.wire_fleet",
      "description": "Wire Fleet agent to SK skills and Micronaut runtime",
      "method": "POST",
      "path": "/skill/agentic/wire-fleet"
    },
    "configure_agent_pipeline": {
      "action": "configure_agent_pipeline",
      "skill_intent": "agentic.configure_pipeline",
      "description": "Configure multi-agent pipeline with routing and dependencies",
      "method": "POST",
      "path": "/skill/agentic/pipeline"
    },
    "emit_agent_event": {
      "action": "emit_agent_event",
      "skill_intent": "agentic.emit_event",
      "description": "Emit event to trigger agent coordination",
      "method": "POST",
      "path": "/skill/agentic/event"
    },
    "validate_agent_contract": {
      "action": "validate_agent_contract",
      "skill_intent": "agentic.validate",
      "description": "Validate agent contract and action parity",
      "method": "POST",
      "path": "/skill/agentic/validate"
    },
    "export_agent_definition": {
      "action": "export_agent_definition",
      "skill_intent": "agentic.export",
      "description": "Export agent definition for deployment",
      "method": "POST",
      "path": "/skill/agentic/export"
    }
  },
  "intents": {
    "agentic.arbitrate": {
      "parameters": {
        "decisions": { "type": "array", "items": { "type": "object" } },
        "context": { "type": "object" },
        "tiebreaker": { "type": "string", "enum": ["consensus", "weighted", "priority"] }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "decision": { "type": "object" },
        "rationale": { "type": "string" },
        "confidence": { "type": "number" }
      }
    },
    "agentic.project_skill": {
      "parameters": {
        "skill_name": { "type": "string" },
        "source_format": { "type": "string", "enum": ["markdown", "json", "yaml"] },
        "target_runtime": { "type": "string", "default": "xcfe" }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "projected_skill": { "type": "object" },
        "routes": { "type": "object" },
        "actions": { "type": "array" }
      }
    },
    "agentic.resolve_agent": {
      "parameters": {
        "agent_id": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "resolved": { "type": "object" },
        "execution": { "type": "object" }
      }
    },
    "agentic.list_registry": {
      "parameters": {
        "filter": { "type": "string", "default": "" }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "models": { "type": "array" },
        "skills": { "type": "array" },
        "agents": { "type": "array" }
      }
    },
    "agentic.pack_shard": {
      "parameters": {
        "agent_id": { "type": "string" },
        "format": { "type": "string", "enum": ["scxqdds", "scxq7", "xshard"] }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "shard_path": { "type": "string" },
        "size": { "type": "number" },
        "compression_ratio": { "type": "number" }
      }
    },
    "agentic.wire_fleet": {
      "parameters": {
        "agent_name": { "type": "string", "enum": ["planner", "executor", "coordinator", "responder", "diagnostician"] },
        "skills": { "type": "array", "items": { "type": "string" } },
        "micronaut_actions": { "type": "array", "items": { "type": "string" } }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "wired_agent": { "type": "object" },
        "skills_bound": { "type": "number" },
        "actions_bound": { "type": "number" }
      }
    },
    "agentic.configure_pipeline": {
      "parameters": {
        "agents": { "type": "array", "items": { "type": "string" } },
        "routing": { "type": "object" },
        "fallback_chain": { "type": "array", "items": { "type": "string" } }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "pipeline": { "type": "object" },
        "routes_registered": { "type": "number" }
      }
    },
    "agentic.emit_event": {
      "parameters": {
        "event_type": { "type": "string" },
        "payload": { "type": "object" },
        "targets": { "type": "array", "items": { "type": "string" } }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "event_id": { "type": "string" },
        "listeners_triggered": { "type": "number" }
      }
    },
    "agentic.validate": {
      "parameters": {
        "agent_id": { "type": "string" }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "contract_valid": { "type": "boolean" },
        "issues": { "type": "array" },
        "action_parity": { "type": "object" }
      }
    },
    "agentic.export": {
      "parameters": {
        "agent_id": { "type": "string" },
        "format": { "type": "string", "enum": ["json", "yaml", "markdown"] }
      },
      "returns": {
        "ok": { "type": "boolean" },
        "definition": { "type": "object" },
        "export_path": { "type": "string" }
      }
    }
  },
  "glossary": [
    { "term": "arbitrate", "definition": "Multi-agent decision arbitration with consensus or priority tiebreaking" },
    { "term": "project_skill", "definition": "Convert skill from source format (markdown, json, yaml) into Micronaut-style runtime format" },
    { "term": "resolve_agent", "definition": "Deterministically resolve agent configuration and dependencies with constructor chain tracing" },
    { "term": "list_registry", "definition": "List all registered models, skills, agents in the agentic system" },
    { "term": "pack_shard", "definition": "Compress agent into deployable shard (SCXQDDS, SCXQ7, or XSHARD format)" },
    { "term": "wire_fleet_agent", "definition": "Connect Fleet agent to SK-1 skills and Micronaut runtime actions (deterministic)" },
    { "term": "configure_agent_pipeline", "definition": "Set up multi-agent orchestration with routing rules, fallback chains, and event handlers" },
    { "term": "emit_agent_event", "definition": "Broadcast event to trigger agent coordination across fleet" },
    { "term": "validate_agent_contract", "definition": "Verify action/route/intent parity and contract compliance" },
    { "term": "export_agent_definition", "definition": "Export agent as markdown, yaml, or json for sharing or deployment" },
    { "term": "XCFE", "definition": "eXtended Control Flow Execution — deterministic model runtime with no stochastic drift" },
    { "term": "SK-1", "definition": "Semantic Kernel agent orchestrator with 5 agents and 49 skills" },
    { "term": "Fleet", "definition": "5-agent orchestrator (planner, executor, coordinator, responder, diagnostician)" },
    { "term": "Micronaut", "definition": "Micro-model runtime with deterministic actions, DI, scheduling, events" },
    { "term": "action_parity", "definition": "Verification that every route target exists in action class and vice versa" },
    { "term": "deterministic", "definition": "Same input produces same output every time; no randomness, reproducible execution" }
  ]
}
