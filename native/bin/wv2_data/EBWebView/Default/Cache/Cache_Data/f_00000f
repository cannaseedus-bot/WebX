      async handleCrew(text){
        if(!text) return;
        this.logUser(text);
        const [tagRaw,...rest]=text.split(":");
        const tag=(tagRaw||"").trim();
        const content=(rest.join(":")||text).trim();
        const Crew={
          nav:q=>`Navigator: plotting course — "${q}"`,
          eng:q=>`Engineer: rerouting power for "${q}"`,
          ana:q=>`Analyst: running heuristics on "${q}"`
        };
        if(Crew[tag]) this.logSys(Crew[tag](content));

        const token=this.hfTokenInput.value.trim();
        if(token){
          try{
            const out = await this.hfChat(token,[
              {role:"user",content:[{type:"text",text:content}]}
            ]);
            const reply=out?.choices?.[0]?.message?.content?.[0]?.text || JSON.stringify(out);
            this.logAI(reply);
          }catch(e){
            this.logSys("HF error: "+e.message);
          }
        }else{
          // offline echo
          const echo=content.split("").reverse().join("");
          this.logAI(echo+" • [local echo]");
        }
        this.aiInput.value="";
      }

