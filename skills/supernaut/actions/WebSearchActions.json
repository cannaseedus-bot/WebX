{
  "class": "WebSearchActions",
  "methods": {
    "search":  { "params": ["query"],         "body": [{"op": "json", "value": {"ok": true, "execution": "web-search.search",  "query": "$query"}}] },
    "answer":  { "params": ["query"],         "body": [{"op": "json", "value": {"ok": true, "execution": "web-search.answer",  "query": "$query"}}] },
    "compose": { "params": ["query", "mode"], "body": [{"op": "json", "value": {"ok": true, "execution": "web-search.compose", "query": "$query", "mode": "$mode"}}] },
    "policy":  { "params": [],                "body": [{"op": "json", "value": {"ok": true, "execution": "web-search.policy"}}] },
    "health":  { "params": [],                "body": [{"op": "json", "value": {"ok": true, "execution": "web-search.health",  "port": 3153}}] }
  }
}