            p.plan.forEach((step,i)=>{
              const row=document.createElement("div");
              row.style.cssText="display:flex;align-items:center;gap:8px;padding:6px 10px;background:#12121c;border:1px solid #1e1e30;border-radius:4px;font-family:monospace;font-size:10px;";
              row.innerHTML=`<span style="color:#444;min-width:16px">${String(i+1).padStart(2,'0')}</span><span style="color:#f0c040;font-weight:bold">@${step.op}</span><span style="color:#888">${Object.entries(step).filter(([k])=>k!=='op').map(([k,v])=>`${k}="${v}"`).join(' ')}</span>`;
              planWrap.appendChild(row);
            });
            detail.appendChild(planWrap);

            // depends
            if(p.depends.length){
              detail.appendChild(lbl("DEPENDENCIES"));
              const depRow=document.createElement("div");depRow.style.cssText="display:flex;gap:6px;flex-wrap:wrap;";
              p.depends.forEach(d=>{
                const dep=PLUGINS.find(x=>x.id===d);
                const chip=document.createElement("div");
                chip.style.cssText="padding:3px 10px;background:#1a1a26;border:1px solid #2a2a40;border-radius:3px;font-family:monospace;font-size:10px;color:#a78bfa;cursor:pointer;";
                chip.textContent=d+(dep?` v${dep.version}`:'');
                chip.onclick=()=>{selected=dep||selected;buildList();renderDetail();};
                depRow.appendChild(chip);
