{
  "class": "VsNativeToolsActions",
  "methods": {
    "x64": {
      "params": [],
      "body": [
        {"op": "exec", "cmd": "cmd /c vcvars64.bat", "result": "env"},
        {"op": "json", "value": {"ok": true, "execution": "vs-native-tools.x64", "arch": "x64", "env": "$env"}}
      ]
    },
    "x86": {
      "params": [],
      "body": [
        {"op": "exec", "cmd": "cmd /c vcvars32.bat", "result": "env"},
        {"op": "json", "value": {"ok": true, "execution": "vs-native-tools.x86", "arch": "x86"}}
      ]
    },
    "x86x64": {
      "params": [],
      "body": [
        {"op": "exec", "cmd": "cmd /c vcvarsx86_amd64.bat", "result": "env"},
        {"op": "json", "value": {"ok": true, "execution": "vs-native-tools.x86_x64", "arch": "x86_x64"}}
      ]
    },
    "x64x86": {
      "params": [],
      "body": [
        {"op": "exec", "cmd": "cmd /c vcvarsamd64_x86.bat", "result": "env"},
        {"op": "json", "value": {"ok": true, "execution": "vs-native-tools.x64_x86", "arch": "x64_x86"}}
      ]
    }
  }
}