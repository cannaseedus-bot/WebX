// neural_layer.klsl
// Dense (fully-connected) neural network layer as a KLSL compute shader.
//
// Compile:  klslc neural_layer.klsl
// Output:   neural_layer.hlsl  (dispatch with [16,16,1] thread groups)
//
// cbuffer layout (DenseConst):
//   uint in_dim;    // K
//   uint out_rows;  // M  (batch)
//   uint out_cols;  // N  (output neurons)
//   uint _pad;

‚üÅ shader dense_layer

  ‚üÅWo‚üÅ stage "compute"
  ‚üÅWo‚üÅ threads [16, 16, 1]

  ‚üÅWo‚üÅ StructuredBuffer<float>    input_buf  : register(t0)
  ‚üÅWo‚üÅ StructuredBuffer<float>    weight_buf : register(t1)
  ‚üÅWo‚üÅ StructuredBuffer<float>    bias_buf   : register(t2)
  ‚üÅWo‚üÅ RWStructuredBuffer<float>  out_buf    : register(u0)
  ‚üÅWo‚üÅ ConstantBuffer<DenseConst> cb         : register(b0)

  [Pop dense_forward]
    ‚üÅWo‚üÅ uint row = SV_DispatchThreadID.y
    ‚üÅWo‚üÅ uint col = SV_DispatchThreadID.x
    ‚üÅSek‚üÅ if (row >= cb.out_rows || col >= cb.out_cols) return

    ‚üÅWo‚üÅ float acc = 0.0f
    ‚üÅK'ayab'‚üÅ uint k in 0 .. cb.in_dim
      ‚üÅWo‚üÅ float a = input_buf[row * cb.in_dim + k]
      ‚üÅWo‚üÅ float w = weight_buf[col * cb.in_dim + k]
      ‚üÅSek‚üÅ acc += a * w
    ‚üÅKumk'u‚üÅ

    // Add bias + ReLU activation
    ‚üÅSek‚üÅ acc += bias_buf[col]
    ‚üÅSek‚üÅ if (acc < 0.0f) acc = 0.0f
    ‚üÅSek‚üÅ out_buf[row * cb.out_cols + col] = acc
  [Xul]

‚üÅXul‚üÅ
