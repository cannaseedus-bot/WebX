{
  "class": "Winkit81Actions",
  "methods": {
    "query_winmd": {
      "params": ["apiName"],
      "body": [
        {
          "op": "set",
          "var": "winmdInfo",
          "value": {
            "apiName": "$apiName",
            "winmdPath": "C:\\Program Files (x86)\\Windows Kits\\8.1\\References\\CommonConfiguration\\Neutral\\Annotated\\Windows.winmd",
            "sdkRoot": "C:\\Program Files (x86)\\Windows Kits\\8.1",
            "description": "Windows 8.1 WinRT type metadata — all annotated Windows 8.1 API contracts",
            "notes": "No headers or libs included. For .winmd processing use mdmerge.exe or winmdidl.exe."
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "winkit-81.query_winmd",
              "mode": "deterministic"
            },
            "winmd": "$winmdInfo"
          }
        }
      ]
    }
  }
}
