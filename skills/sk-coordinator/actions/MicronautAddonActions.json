{
  "class": "MicronautAddonActions",
  "methods": {
    "start_project": {
      "params": ["projectName"],
      "body": [
        {
          "op": "load",
          "from": "../micronaut/config/application.json",
          "into": "baseConfig"
        },
        {
          "op": "set",
          "var": "project",
          "value": {
            "name": "$projectName",
            "status": "initialized",
            "environment": "$baseConfig.environment",
            "components": "$baseConfig.components"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "micronaut.init",
            "project": "$project"
          }
        }
      ]
    },
    "configure_endpoint": {
      "params": ["path", "method"],
      "body": [
        {
          "op": "set",
          "var": "gateway",
          "value": {
            "endpoint": "$path",
            "method": "$method"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "micronaut.configure",
            "gateway": "$gateway"
          }
        }
      ]
    },
    "secure_endpoint": {
      "params": ["role"],
      "body": [
        {
          "op": "compare",
          "opType": "eq",
          "a": "$role",
          "b": "admin",
          "into": "isAdmin"
        },
        {
          "op": "compare",
          "opType": "eq",
          "a": "$role",
          "b": "developer",
          "into": "isDeveloper"
        },
        {
          "op": "compare",
          "opType": "eq",
          "a": "$role",
          "b": "ops",
          "into": "isOps"
        },
        {
          "op": "set",
          "var": "allowed",
          "value": "$isAdmin"
        },
        {
          "op": "if",
          "cond": {
            "var": "isDeveloper"
          },
          "then": [
            {
              "op": "set",
              "var": "allowed",
              "value": true
            }
          ]
        },
        {
          "op": "if",
          "cond": {
            "var": "isOps"
          },
          "then": [
            {
              "op": "set",
              "var": "allowed",
              "value": true
            }
          ]
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "micronaut.secure",
            "role": "$role",
            "allowed": "$allowed"
          }
        }
      ]
    },
    "inject_bean": {
      "params": ["beanName"],
      "body": [
        {
          "op": "load",
          "from": "../micronaut/config/application.json",
          "into": "system"
        },
        {
          "op": "set",
          "var": "di",
          "value": "$system.components"
        },
        {
          "op": "setProp",
          "target": "$di",
          "path": "$beanName",
          "value": {
            "status": "available",
            "scope": "singleton",
            "dependencies": [
              "configuration",
              "env"
            ]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "micronaut.inject",
            "bean": "$beanName",
            "di": "$di"
          }
        }
      ]
    },
    "schedule_task": {
      "params": ["task", "cron"],
      "body": [
        {
          "op": "set",
          "var": "scheduled",
          "value": {
            "task": "$task",
            "cron": "$cron"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "micronaut.schedule",
            "scheduled": "$scheduled"
          }
        }
      ]
    },
    "event_bridge": {
      "params": ["topic", "payload"],
      "body": [
        {
          "op": "set",
          "var": "event",
          "value": {
            "topic": "$topic",
            "payload": "$payload",
            "status": "emitted"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "micronaut.event",
            "event": "$event",
            "listeners": [
              "MicronautAddonActions.start_project",
              "MicronautAddonActions.secure_endpoint",
              "MicronautAddonActions.inject_bean"
            ]
          }
        }
      ]
    }
  }
}
