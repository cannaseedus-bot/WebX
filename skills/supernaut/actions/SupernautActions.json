{
  "class": "SupernautActions",
  "methods": {
    "health": {
      "params": [],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "skill": "supernaut",
              "intent": "health"
            },
            "status": "ready"
          }
        }
      ]
    },
    "modelProbe": {
      "params": [],
      "body": [
        {
          "op": "tool",
          "tool": "model.dispatch",
          "args": {
            "mode": "hybrid",
            "backend": "manifest"
          },
          "into": "miniModelSummary"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "skill": "supernaut",
              "intent": "model_probe"
            },
            "miniModel": "$miniModelSummary"
          }
        }
      ]
    },
    "modelList": {
      "params": [],
      "body": [
        {
          "op": "tool",
          "tool": "model.catalog",
          "args": {},
          "into": "modelCatalog"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "skill": "supernaut",
              "intent": "model_list"
            },
            "models": "$modelCatalog.models",
            "modelCount": "$modelCatalog.modelCount"
          }
        }
      ]
    },
    "modelSelect": {
      "params": ["agentId"],
      "body": [
        {
          "op": "tool",
          "tool": "model.catalog",
          "args": {
            "agentId": "$agentId"
          },
          "into": "modelCatalog"
        },
        {
          "op": "get",
          "from": "$modelCatalog",
          "path": "selected.path",
          "into": "selectedManifest"
        },
        {
          "op": "if",
          "cond": {
            "var": "selectedManifest"
          },
          "then": [
            {
              "op": "tool",
              "tool": "model.dispatch",
              "args": {
                "mode": "hybrid",
                "backend": "manifest",
                "manifestPath": "$selectedManifest"
              },
              "into": "selectedSummary"
            },
            {
              "op": "json",
              "value": {
                "ok": true,
                "execution": {
                  "skill": "supernaut",
                  "intent": "model_select"
                },
                "agentId": "$agentId",
                "manifestPath": "$selectedManifest",
                "miniModel": "$selectedSummary"
              }
            }
          ],
          "else": [
            {
              "op": "status",
              "value": 404
            },
            {
              "op": "json",
              "value": {
                "ok": false,
                "error": "agent_model_not_found",
                "agentId": "$agentId"
              }
            }
          ]
        }
      ]
    }
  }
}
