{
  "class": "PowerShellAgentActions",
  "methods": {
    "health": {
      "params": [],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "agent": "powershell-agent",
            "execution": {
              "skill": "powershell-agent",
              "intent": "health"
            },
            "capabilities": [
              "powershell.catalog",
              "powershell.exec",
              "model.dispatch"
            ]
          }
        }
      ]
    },
    "scaffoldLayout": {
      "params": [],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "skill": "powershell-agent",
              "intent": "layout"
            },
            "layout": {
              "orchestrator": [
                "scripts/agent-os-powershell/orchestrator/orchestrator.ps1",
                "scripts/agent-os-powershell/orchestrator/node-register.ps1",
                "scripts/agent-os-powershell/orchestrator/task-dispatcher.ps1",
                "scripts/agent-os-powershell/orchestrator/gpu-dispatcher.ps1"
              ],
              "workers": [
                "scripts/agent-os-powershell/workers/worker.ps1",
                "scripts/agent-os-powershell/workers/gpu-worker.ps1",
                "scripts/agent-os-powershell/workers/run-agent.ps1"
              ],
              "swarm": [
                "scripts/agent-os-powershell/swarm/swarm-launch.ps1",
                "scripts/agent-os-powershell/swarm/swarm-stop.ps1",
                "scripts/agent-os-powershell/swarm/swarm-status.ps1"
              ]
            }
          }
        }
      ]
    },
    "commandCatalog": {
      "params": [],
      "body": [
        {
          "op": "tool",
          "tool": "powershell.catalog",
          "args": {},
          "into": "scriptCatalog"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "skill": "powershell-agent",
              "intent": "catalog"
            },
            "scripts": "$scriptCatalog.scripts",
            "count": "$scriptCatalog.count"
          }
        }
      ]
    },
    "runCommand": {
      "params": ["scriptPath", "scriptArgs", "dryRun"],
      "body": [
        {
          "op": "tool",
          "tool": "powershell.exec",
          "args": {
            "scriptPath": "$scriptPath",
            "scriptArgs": "$scriptArgs",
            "dryRun": "$dryRun"
          },
          "into": "runResult"
        },
        {
          "op": "json",
          "value": {
            "ok": "$runResult.ok",
            "execution": {
              "skill": "powershell-agent",
              "intent": "run"
            },
            "result": "$runResult"
          }
        }
      ]
    }
  }
}
