{
  "class": "SemanticPlannerActions",
  "methods": {
    "generate_learning_plan": {
      "params": ["topic", "timeframe"],
      "body": [
        {
          "op": "set",
          "var": "plan",
          "value": {
            "goal": "$topic",
            "steps": [
              "survey current knowledge",
              "study canonical resources",
              "build a micronaut sample",
              "reflect on learnings"
            ]
          }
        },
        {
          "op": "set",
          "var": "due",
          "value": "$timeframe"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "plan": "$plan",
            "timeframe": "$due",
            "execution": "learning.plan"
          }
        }
      ]
    },
    "build_multi_step_plan": {
      "params": ["goal", "steps"],
      "body": [
        {
          "op": "set",
          "var": "plan",
          "value": {
            "goal": "$goal",
            "orchestration": "$steps"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "orchestration.plan",
            "plan": "$plan"
          }
        }
      ]
    }
  }
}
