{
  "class": "DatasetTrainingActions",
  "methods": {
    "generateManifest": {
      "params": ["corpus_dir", "output"],
      "body": [
        {"op": "exec", "cmd": "node scripts/generate_dataset_manifest.js \"$corpus_dir\" \"$output\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "dataset-training.generate_manifest", "corpus": "$corpus_dir", "output": "$output", "result": "$out"}}
      ]
    },
    "discover": {
      "params": ["root"],
      "body": [
        {"op": "exec", "cmd": "node scripts/generate_dataset_manifest.js \"$root\" --discover", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "dataset-training.discover", "root": "$root", "result": "$out"}}
      ]
    },
    "ingest": {
      "params": ["source", "format"],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "dataset-training.ingest", "source": "$source", "format": "$format"}}
      ]
    },
    "status": {
      "params": [],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "dataset-training.status"}}
      ]
    }
  }
}