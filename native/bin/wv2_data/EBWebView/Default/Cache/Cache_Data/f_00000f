      makePacman(){
        const cvs=document.createElement("canvas");
        cvs.width=640;cvs.height=220;
        const ctx=cvs.getContext("2d");
        const W=cvs.width,H=cvs.height;
        const grid=20,cols=(W/grid)|0,rows=(H/grid)|0;
        const dots=new Set();
        for(let y=2;y<rows-2;y++){
          for(let x=2;x<cols-2;x++){
            if((x+y)%2===0) dots.add(x+","+y);
          }
        }
        const state={t:0,last:performance.now(),px:3,py:3,vx:1,vy:0,score:0};
        (function step(now){
          requestAnimationFrame(step);
          const dt=Math.min(.033,(now-(state.last||now))/1000);
          state.last=now;state.t+=dt;
          if(((state.t*5)|0)%1===0){
            state.px+=state.vx;state.py+=state.vy;
            if(state.px<2) state.px=cols-3;
            if(state.px>cols-3) state.px=2;
            const key=state.px+","+state.py;
            if(dots.has(key)){dots.delete(key);state.score+=10;}
            if(Math.random()<.2){
              const dirs=[[1,0],[-1,0],[0,1],[0,-1]];
              const d=dirs[(Math.random()*4)|0];
              state.vx=d[0];state.vy=d[1];
            }
          }
          ctx.fillStyle="#000";ctx.fillRect(0,0,W,H);
          ctx.strokeStyle="#0af";ctx.lineWidth=1;
          for(let x=0;x<W;x+=grid){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
          for(let y=0;y<H;y+=grid){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
          ctx.fillStyle="#ff0";
          dots.forEach(k=>{
            const [x,y]=k.split(",").map(Number);
            ctx.fillRect(x*grid+grid/2-2,y*grid+grid/2-2,4,4);
          });
          const px=state.px*grid+grid/2;const py=state.py*grid+grid/2;
          ctx.fillStyle="#ff6fd8";ctx.beginPath();ctx.arc(px,py,8,0,Math.PI*2);ctx.fill();
          ctx.fillStyle="#0fa";ctx.font="12px monospace";
          ctx.fillText("Score "+state.score,10,18);
        })(performance.now());
        return this.makeCard("Ms. Pac-Man (lite)",cvs);
      }

