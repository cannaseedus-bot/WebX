{
  "class": "MicronautModelActions",
  "methods": {
    "backends": {
      "params": [],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.backends"}}]
    },
    "catalog": {
      "params": [],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.catalog"}}]
    },
    "xjsonFormat": {
      "params": ["model_id"],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.xjson_format", "model": "$model_id"}}]
    },
    "foldMap": {
      "params": ["model_id"],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.fold_map", "model": "$model_id"}}]
    },
    "new": {
      "params": ["name", "backend", "weights"],
      "body": [
        {"op": "set", "var": "spec", "value": {"name": "$name", "backend": "$backend", "weights": "$weights"}},
        {"op": "json", "value": {"ok": true, "execution": "micronaut-model.new", "spec": "$spec"}}
      ]
    },
    "register": {
      "params": ["model_id", "registry"],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.register", "model": "$model_id", "registry": "$registry"}}]
    },
    "list": {
      "params": [],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.list"}}]
    },
    "fetchWeights": {
      "params": ["model_id", "source"],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.fetch_weights", "model": "$model_id", "source": "$source"}}]
    },
    "nativeBridge": {
      "params": ["model_id"],
      "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-model.native_bridge", "model": "$model_id"}}]
    }
  }
}