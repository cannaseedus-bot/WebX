{
  "class": "SkillActions",
  "methods": {
    "handle": {
      "params": [],
      "body": [
        { "op": "return", "value": { "ok": true } }
      ]
    },
    "ping": {
      "params": [],
      "body": [
        { "op": "json", "value": { "pong": true } },
        { "op": "return", "value": { "pong": true } }
      ]
    },
    "echo": {
      "params": ["message"],
      "body": [
        { "op": "json", "value": { "echo": "$message" } },
        { "op": "return", "value": { "echo": "$message" } }
      ]
    }
  }
}

