<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>PRIME-IFAL v4 — ASX PRIME COMMAND COCKPIT</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    :root{
      --cyan:#00ffff;--lime:#00ff00;--yellow:#ffff00;
      --bg:#000000;--panel:rgba(0,0,0,0.86);--line:rgba(0,255,255,0.6);
    }
    *{box-sizing:border-box}
    html,body{
      margin:0;background:var(--bg);color:#0ff;
      font-family:'Orbitron','Courier New',monospace;overflow:hidden;
    }
    #star-field{position:fixed;inset:0;background:#000;z-index:0;}
    .star-layer{position:absolute;inset:0;animation:starScroll 20s linear infinite;}
    @keyframes starScroll{from{transform:translateY(0)}to{transform:translateY(100%)}}
    .star{position:absolute;border-radius:50%;}
    .star.cyan{background:#0ff;box-shadow:0 0 10px #0ff;}
    .star.yellow{background:#ff0;box-shadow:0 0 10px #ff0;}
    .star.white{background:#fff;box-shadow:0 0 6px #fff;}

    .hud-frame{
      position:fixed;inset:40px;border:3px solid var(--line);
      box-shadow:inset 0 0 30px rgba(0,255,255,.3),0 0 30px rgba(0,255,255,.3);
      pointer-events:none;z-index:1;animation:framePulse 3s ease-in-out infinite;
    }
    @keyframes framePulse{
      0%,100%{border-color:rgba(0,255,255,.6)}
      50%{border-color:rgba(0,255,255,.9)}
    }
    .scanlines{
      position:fixed;inset:0;
      background:linear-gradient(transparent 0%,rgba(0,255,255,.04) 50%,transparent 100%);
      background-size:100% 5px;pointer-events:none;z-index:999;
      animation:scanline 10s linear infinite;
    }
    @keyframes scanline{
      0%{background-position:0 0}
      100%{background-position:0 100%}
    }

    .asx-logo{
      position:absolute;top:8%;left:50%;transform:translateX(-50%);
      text-align:center;z-index:2;user-select:none;pointer-events:none;
    }
    .asx-title{
      font-size:90px;font-weight:900;letter-spacing:14px;color:#0ff;
      text-shadow:0 0 10px #0ff,0 0 20px #0ff,0 0 40px #0ff;
      animation:titlePulse 2s ease-in-out infinite;
    }
    .asx-subtitle{
      font-size:16px;letter-spacing:6px;color:#ff0;
      text-shadow:0 0 10px #ff0,0 0 20px #ff0;margin-top:6px;font-weight:700;
    }
    @keyframes titlePulse{
      0%,100%{text-shadow:0 0 10px #0ff,0 0 20px #0ff,0 0 40px #0ff}
      50%{text-shadow:0 0 20px #0ff,0 0 40px #0ff,0 0 80px #0ff,0 0 120px #0ff}
    }

    .crosshair{
      position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);
      width:70px;height:70px;z-index:2;pointer-events:none;
    }
    .crosshair::before,.crosshair::after{
      content:"";position:absolute;background:#0ff;box-shadow:0 0 8px #0ff;
    }
    .crosshair::before{left:0;right:0;top:50%;height:2px;transform:translateY(-50%);}
    .crosshair::after{top:0;bottom:0;left:50%;width:2px;transform:translateX(-50%);}

    .dock{
      position:fixed;left:50%;bottom:7%;transform:translateX(-50%);
      display:grid;grid-template-columns:repeat(3,1fr);gap:16px;z-index:3;
    }
    .btn{
      width:220px;height:80px;
      background:linear-gradient(135deg,rgba(0,255,255,.15),rgba(0,255,0,.1));
      border:3px solid #0ff;color:#0ff;font-size:15px;font-weight:bold;
      cursor:pointer;position:relative;transition:all .25s;
      text-decoration:none;display:flex;align-items:center;justify-content:center;
      flex-direction:column;text-transform:uppercase;letter-spacing:2px;
      clip-path:polygon(15% 0%,100% 0%,85% 100%,0% 100%);
      box-shadow:0 0 25px rgba(0,255,255,.4);
    }
    .btn:hover{
      background:linear-gradient(135deg,rgba(0,255,255,.4),rgba(0,255,0,.3));
      border-color:#0f0;color:#0f0;box-shadow:0 0 50px rgba(0,255,255,.8);
      transform:scale(1.06) translateY(-3px);
    }
    .btn.engage{
      grid-column:1/-1;width:100%;height:110px;font-size:32px;
      background:linear-gradient(135deg,rgba(255,255,0,.25),rgba(0,255,255,.2));
      border-color:#ff0;color:#ff0;
      clip-path:polygon(5% 0%,95% 0%,100% 50%,95% 100%,5% 100%,0% 50%);
      animation:engagePulse 1.6s ease-in-out infinite;
    }
    @keyframes engagePulse{
      0%,100%{box-shadow:0 0 30px rgba(255,255,0,.6);transform:scale(1)}
      50%{box-shadow:0 0 70px rgba(255,255,0,.9);transform:scale(1.02)}
    }

    .overlay{
      position:fixed;inset:80px;z-index:5;display:none;
    }
    .overlay.show{
      display:grid;grid-template-columns:320px 1fr;gap:12px;overflow:hidden;
    }
    .panel{
      background:var(--panel);border:1px solid rgba(0,255,255,.35);
      border-radius:12px;box-shadow:0 0 24px rgba(0,255,255,.2);
    }
    /* right panel (module host) must clip its content */
    .overlay.show > .panel.stack:last-child{overflow:hidden;min-height:0;display:grid;grid-template-rows:auto 1fr;gap:10px;height:100%;}
    /* left panel keeps normal stack layout */
    .stack{display:grid;grid-template-rows:auto 1fr auto;gap:10px;height:100%;}
    .panel.heads{
      display:flex;align-items:center;justify-content:space-between;
      padding:10px 12px;border-bottom:1px solid rgba(0,255,255,.25);
    }
    .title{font-weight:900;letter-spacing:2px;}
    .close{
      appearance:none;border:2px solid #0ff;background:transparent;color:#0ff;
      border-radius:8px;padding:6px 10px;font-weight:800;cursor:pointer;
    }
    .scroll{overflow:auto;padding:12px;}
    /* activeView: full-height module host — no class scroll, modules set their own overflow */
    #activeView{overflow:hidden;padding:0;min-height:0;display:flex;flex-direction:column;}
    .term{
      background:#000;color:#0f0;height:260px;overflow:auto;
      border:1px solid #0f0;border-radius:8px;padding:10px;
      font-family:'Courier New',monospace;font-size:13px;
    }
    .tabs{display:flex;gap:8px;flex-wrap:wrap;}
    .tab{
      padding:8px 12px;border:1px solid rgba(0,255,255,.35);border-radius:999px;
      background:rgba(0,255,255,.08);cursor:pointer;font-size:12px;
    }
    .tab.active{background:rgba(255,255,0,.1);border-color:#ff0;color:#ff0;}

    .grid{
      display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;
    }
    .mini-runtime{
      position:relative;background:#051119;border:1px solid rgba(0,255,255,.25);
      border-radius:12px;overflow:hidden;
    }
    .mini-runtime canvas{
      display:block;width:100%;height:220px;background:#000;
    }
    .mini-hud{
      position:absolute;left:10px;bottom:10px;display:flex;gap:8px;
    }
    .badge{
      border:1px solid rgba(0,255,255,.45);background:rgba(0,255,255,.08);
      padding:4px 8px;border-radius:8px;font-size:11px;
    }
    iframe.guide{width:100%;height:220px;border:none;background:#020;}
    .pdf-wrap{height:500px;}
    .pdf-wrap embed{width:100%;height:100%;border:none;}

    /* PRIME CHAT MODAL */
    #primeModal{
      position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);
      width:520px;max-width:92%;background:rgba(0,0,0,.92);
      border:2px solid #0ff;border-radius:16px;box-shadow:0 0 36px rgba(0,255,255,.6);
      z-index:6;display:none;
    }
    #primeModalHead{
      display:flex;align-items:center;justify-content:space-between;
      padding:10px 14px;border-bottom:1px solid rgba(0,255,255,.4);
    }
    #primeModalBody{padding:10px 14px;max-height:340px;overflow:auto;}
    #primeChatLog{
      background:#000;border:1px solid #0f0;border-radius:8px;padding:8px;
      height:180px;overflow:auto;font-family:'Courier New',monospace;
      font-size:12px;color:#aaffaa;margin-top:8px;margin-bottom:4px;
    }
    #primeChatInput{
      width:100%;background:#001100;color:#aaffaa;
      border:1px solid #004400;border-radius:8px;padding:6px 8px;
      font-family:'Courier New',monospace;
    }
    #primeChatSend{margin-top:6px;float:right;}

    @media(max-width:1200px){
      .overlay.show{grid-template-columns:1fr;}
      .dock{grid-template-columns:1fr;gap:10px;width:90%;}
      .asx-title{font-size:60px;letter-spacing:6px;}
      .hud-frame{inset:20px;}
    }

    /* GPU DEBUG HUD */
    .dbg-layout{display:grid;grid-template-columns:200px 1fr 1fr;gap:10px;height:100%;padding:10px;}
    .dbg-panel{background:#000b16;border:1px solid rgba(0,255,255,.25);border-radius:8px;padding:10px;}
    .dbg-label{font-size:11px;letter-spacing:2px;color:#0ff;margin-bottom:8px;text-transform:uppercase;}
    .slot-row{display:flex;flex-direction:column;gap:6px;}
    .slot-box{
      display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:6px;
      border:1px solid rgba(0,255,255,.2);background:#020c14;font-size:12px;
      transition:background .3s,border-color .3s,box-shadow .3s;
    }
    .slot-box.compute{background:rgba(0,255,80,.12);border-color:#00ff50;box-shadow:0 0 10px rgba(0,255,80,.4);color:#00ff50;}
    .slot-box.load{background:rgba(255,220,0,.1);border-color:#ffdc00;box-shadow:0 0 10px rgba(255,220,0,.3);color:#ffdc00;}
    .slot-box.prefetch{background:rgba(0,150,255,.08);border-color:#0096ff;box-shadow:0 0 6px rgba(0,150,255,.2);color:#0096ff;}
    .slot-box.idle{background:#020c14;border-color:rgba(0,255,255,.15);color:rgba(0,255,255,.35);}
    .slot-name{font-weight:900;font-size:15px;width:20px;}
    .slot-status{font-size:10px;letter-spacing:1px;text-transform:uppercase;}
    .slot-tile{font-size:9px;opacity:.7;margin-left:auto;}
    .dispatch-wrap{display:flex;flex-direction:column;height:100%;}
    .dispatch-bar-bg{
      background:#020c14;border:1px solid rgba(0,255,255,.2);border-radius:6px;
      height:28px;overflow:hidden;margin-bottom:8px;position:relative;
    }
    .dispatch-bar-fill{
      height:100%;width:0%;
      background:linear-gradient(90deg,#00ffaa,#00ccff);
      box-shadow:0 0 12px rgba(0,255,180,.5);
      transition:width .1s linear;
    }
    .dispatch-stats{font-size:11px;color:rgba(0,255,255,.6);display:flex;gap:10px;flex-wrap:wrap;}
    .dispatch-stat{font-size:11px;}
    .dispatch-stat span{color:#0ff;}
    .op-trace{
      flex:1;background:#000;border:1px solid rgba(0,255,0,.2);border-radius:6px;
      overflow-y:auto;padding:6px;font-family:'Courier New',monospace;
      font-size:11px;color:#00dd88;margin-top:8px;min-height:0;
    }
    .op-line{padding:1px 0;border-bottom:1px solid rgba(0,255,0,.06);}
    .op-line .op-ts{color:rgba(0,255,255,.4);margin-right:6px;}
    .op-line .op-code{color:#00ff88;font-weight:bold;margin-right:4px;}
    .op-line .op-detail{color:rgba(0,255,136,.6);}
    .op-line .op-err{color:#ffaa00;margin-left:4px;}
    canvas.dispatch-canvas{width:100%;height:60px;display:block;border-radius:6px;
      border:1px solid rgba(0,255,255,.15);background:#000;margin-bottom:8px;}
  </style>
</head>
