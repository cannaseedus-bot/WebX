{
  "class": "WorkflowOrchestratorActions",
  "methods": {
    "plan_project": {
      "params": ["goal", "milestones"],
      "body": [
        {
          "op": "set",
          "var": "plan",
          "value": {
            "goal": "$goal",
            "milestones": "$milestones",
            "status": "planned"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "workflow.plan",
            "plan": "$plan"
          }
        }
      ]
    },
    "automate_workflow": {
      "params": ["workflow", "steps"],
      "body": [
        {
          "op": "set",
          "var": "automation",
          "value": {
            "workflow": "$workflow",
            "steps": "$steps",
            "status": "automated"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "workflow.automate",
            "automation": "$automation"
          }
        }
      ]
    },
    "scaffold_kuhul_app": {
      "params": ["appName", "template"],
      "body": [
        {
          "op": "set",
          "var": "scaffold",
          "value": {
            "appName": "$appName",
            "template": "$template",
            "status": "scaffolded"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "workflow.scaffold",
            "scaffold": "$scaffold"
          }
        }
      ]
    }
  }
}
