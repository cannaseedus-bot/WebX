{
  "class": "DolphinCoderActions",
  "methods": {
    "codeReview": {
      "params": ["target"],
      "body": [
        {
          "op": "tool",
          "tool": "repo.review",
          "args": {
            "target": "$target"
          },
          "into": "reviewResult"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "skill": "codex-root",
              "intent": "dolphin_code_review",
              "modelHint": "dolphin-coder"
            },
            "target": "$target",
            "review": "$reviewResult"
          }
        }
      ]
    },
    "bugReport": {
      "params": ["target"],
      "body": [
        {
          "op": "tool",
          "tool": "repo.review",
          "args": {
            "target": "$target"
          },
          "into": "reviewResult"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "skill": "codex-root",
              "intent": "dolphin_bug_report",
              "modelHint": "dolphin-coder"
            },
            "bugReport": {
              "target": "$target",
              "source": "repo.review",
              "findings": "$reviewResult.findings",
              "notes": "$reviewResult.notes"
            }
          }
        }
      ]
    }
  }
}
