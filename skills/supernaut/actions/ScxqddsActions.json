{
  "class": "ScxqddsActions",
  "methods": {
    "decode": {
      "params": ["shard"],
      "body": [
        {"op": "exec", "cmd": "scxqdds_decode.exe \"$shard\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "scxqdds.decode", "shard": "$shard", "result": "$out"}}
      ]
    },
    "selftest": {
      "params": [],
      "body": [
        {"op": "exec", "cmd": "scxqdds_selftest.exe", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "scxqdds.selftest", "result": "$out"}}
      ]
    },
    "vectorRun": {
      "params": ["shard"],
      "body": [
        {"op": "exec", "cmd": "scxqdds_decode.exe \"$shard\" --vector-run", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "scxqdds.vector_run", "shard": "$shard", "result": "$out"}}
      ]
    }
  }
}