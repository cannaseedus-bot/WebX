{
  "class": "CommandsActions",
  "methods": {
    "run": {
      "params": ["command", "args"],
      "body": [
        {
          "op": "set",
          "var": "invocation",
          "value": {
            "command": "$command",
            "args": "$args",
            "shell": "pwsh"
          }
        },
        {
          "op": "tool",
          "tool": "execute_command",
          "args": {
            "command": "$command",
            "args": "$args"
          },
          "into": "result"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "commands.run",
              "mode": "deterministic"
            },
            "invocation": "$invocation",
            "stdout": "$result.stdout",
            "stderr": "$result.stderr",
            "exitCode": "$result.exitCode"
          }
        }
      ]
    }
  }
}
