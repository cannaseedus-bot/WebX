{
  "class": "MatrixPiActions",
  "matrix_version": "π-2.0",
  "description": "MATRIX @π.* operator implementations. Each operator maps an inference mode to a tensor operation to an agent execution call.",
  "registry": "actions/π.registry.json",

  "π_operators": {
    "@π.navigate": {
      "inference": "adjacency → sequence",
      "tensor_op": "translation",
      "execution": "agent.π_navigate()",
      "geodesic": true,
      "modulation": "π"
    },
    "@π.execute": {
      "inference": "containment → scope",
      "tensor_op": "contraction",
      "execution": "agent.π_execute()",
      "harmonic": true,
      "modulation": "π/2"
    },
    "@π.focus": {
      "inference": "symmetry → duality",
      "tensor_op": "projection",
      "execution": "agent.π_focus()",
      "attention": true,
      "modulation": "π/4"
    },
    "@π.transform": {
      "inference": "linear_map → reframe",
      "tensor_op": "linear_map",
      "execution": "agent.π_transform()",
      "matrix": "mat4x4",
      "modulation": "π"
    },
    "@π.rotate": {
      "inference": "rotation → orientation",
      "tensor_op": "rotation",
      "execution": "agent.π_rotate()",
      "quaternion": true,
      "modulation": "π"
    },
    "@π.eval": {
      "inference": "signal_eval → route",
      "tensor_op": "inner_product",
      "execution": "evalPi(action)",
      "formula": "sum(Wo.π.tokens[].weight) * Wo.entropy",
      "modulation": "π"
    }
  },

  "inference_engine": {
    "rule_application": "π-geometric rewrite rules",
    "tensor_field_analysis": "π-harmonic analysis",
    "execution_generation": "π-phase scheduling"
  },

  "methods": {

    "navigate": {
      "params": ["tensor_field", "target"],
      "π": { "glyph": ">", "entropy": 0.2, "signal": 0.16, "route": "agent" },
      "matrix_op": "@π.navigate",
      "body": [
        { "op": "tool", "tool": "matrix.exe",
          "args": { "source": "@π.navigate { field: \"$tensor_field\", target: \"$target\" }" },
          "into": "result" },
        { "op": "json", "value": {
            "ok": true,
            "execution": { "skill": "matrix-sandbox", "intent": "matrix.π.navigate" },
            "π_file": "actions/navigate.π.json",
            "result": "$result"
        }}
      ]
    },

    "execute": {
      "params": ["code", "policy"],
      "π": { "glyph": "#", "entropy": 0.5, "signal": 0.75, "route": "model" },
      "matrix_op": "@π.execute",
      "body": [
        { "op": "tool", "tool": "matrix.exe",
          "args": { "source": "$code", "policy": "$policy" },
          "into": "result" },
        { "op": "json", "value": {
            "ok": true,
            "execution": { "skill": "matrix-sandbox", "intent": "matrix.π.execute" },
            "π_file": "actions/execute.π.json",
            "result": "$result"
        }}
      ]
    },

    "focus": {
      "params": ["target", "mode"],
      "π": { "glyph": "@", "entropy": 0.35, "signal": 1.05, "route": "xjson" },
      "matrix_op": "@π.focus",
      "body": [
        { "op": "tool", "tool": "matrix.exe",
          "args": { "source": "@tick { target: \"$target\", mode: \"$mode\" }" },
          "into": "result" },
        { "op": "json", "value": {
            "ok": true,
            "execution": { "skill": "matrix-sandbox", "intent": "matrix.π.focus" },
            "π_file": "actions/focus.π.json",
            "result": "$result"
        }}
      ]
    },

    "focus_collapse": {
      "params": ["population", "fitness_goal"],
      "π": { "glyph": "@@", "entropy": 0.35, "signal": 1.05, "route": "xjson" },
      "matrix_op": "@π.focus.collapse",
      "body": [
        { "op": "tool", "tool": "matrix.exe",
          "args": { "source": "@collapse { population: \"$population\", goal: \"$fitness_goal\" }" },
          "into": "result" },
        { "op": "json", "value": {
            "ok": true,
            "execution": { "skill": "matrix-sandbox", "intent": "matrix.π.focus.collapse" },
            "π_file": "actions/focus.π.json",
            "result": "$result"
        }}
      ]
    },

    "eval_signal": {
      "params": ["action_name"],
      "π": null,
      "matrix_op": "@π.eval",
      "body": [
        { "op": "json", "value": {
            "ok": true,
            "execution": { "skill": "matrix-sandbox", "intent": "matrix.π.eval_signal" },
            "formula": "sum(Wo.π.tokens[].weight) * Wo.entropy",
            "lookup": "actions/π.registry.json",
            "action": "$action_name"
        }}
      ]
    }

  }
}
