            const titleEl=document.createElement("div");
            titleEl.style.cssText="display:flex;align-items:flex-start;gap:10px;";
            titleEl.innerHTML=`<div style="flex:1"><div style="color:#fff;font-size:16px;font-weight:700">${p.name}</div><div style="color:#555;font-size:10px;margin-top:2px">${p.id} · v${p.version} · ${(p.size/1024).toFixed(1)} KB · ${p.chunks} chunk${p.chunks!==1?'s':''}</div></div>${sigBadge}`;
