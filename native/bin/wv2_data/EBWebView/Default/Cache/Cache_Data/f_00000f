        prime1:        {id:"prime1",        title:"PRIME-1 BUILDER",nodeType:"runtime.prime1",      group:"AI",     icon:"🏗️", desc:"Build new modules from prompt flags"},
        game:          {id:"game",          title:"JSON DUNGEON",   nodeType:"runtime.game",        group:"EXPLORE",icon:"🗝️", desc:"Opcode-native dungeon crawler"},
        gamegallery:   {id:"gamegallery",   title:"GAME GALLERY",   nodeType:"runtime.gamegallery", group:"EXPLORE",icon:"🖼️", desc:"All playable demos"},
        ytgs:          {id:"ytgs",          title:"YT GREEN SCREEN",nodeType:"runtime.ytgs",        group:"EXPLORE",icon:"📺", desc:"VectorGreenScreen player"},
        guides:        {id:"guides",        title:"All Guides",     nodeType:"runtime.guides",      group:"EXPLORE",icon:"🗺️", desc:"Docs & how-tos"}
      }
    };

    // ── KernelTrace: global opcode event log (shared by all modules) ────────────
    window.KernelTrace=(function(){
      const _log=[],_subs=[];let _seq=0;
      return{
        emit(op,input){
          const e={id:'evt_'+String(_seq++).padStart(6,'0'),ts:Date.now(),op,input:input||{},output:null,ms:'…',status:'run'};
          const t0=performance.now();
          _log.push(e);if(_log.length>400)_log.shift();
          _subs.forEach(f=>{try{f(e);}catch(x){}});
          return(out,ms)=>{e.output=out||{};e.ms=ms!==undefined?ms:(performance.now()-t0).toFixed(1);e.status='ok';_subs.forEach(f=>{try{f(e);}catch(x){}}); };
        },
        sub(f){_subs.push(f);return()=>{const i=_subs.indexOf(f);if(i>=0)_subs.splice(i,1);};},
        log(){return[..._log];},
        clear(){_log.length=0;},
        get _seq(){return _seq;}
      };
    })();

