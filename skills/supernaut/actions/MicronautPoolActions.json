{
  "class": "MicronautPoolActions",
  "methods": {
    "list":         { "params": [],                           "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.list"}}] },
    "dispatch":     { "params": ["agent", "payload"],         "body": [{"op": "set", "var": "req", "value": {"agent": "$agent", "payload": "$payload"}}, {"op": "json", "value": {"ok": true, "execution": "micronaut-pool.dispatch", "request": "$req"}}] },
    "invoke":       { "params": ["agent", "action", "args"], "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.invoke", "agent": "$agent", "action": "$action"}}] },
    "healthAll":    { "params": [],                           "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.health_all"}}] },
    "health":       { "params": ["agent"],                    "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.health", "agent": "$agent"}}] },
    "eval":         { "params": ["agent", "prompt"],          "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.eval", "agent": "$agent"}}] },
    "quarantine":   { "params": ["agent", "reason"],          "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.quarantine", "agent": "$agent", "reason": "$reason"}}] },
    "pending":      { "params": [],                           "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.pending"}}] },
    "confirmEvict": { "params": ["agent"],                    "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.confirm_evict", "agent": "$agent"}}] },
    "confirmAllow": { "params": ["agent"],                    "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.confirm_allow", "agent": "$agent"}}] },
    "replay":       { "params": ["agent", "session"],         "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.replay", "agent": "$agent"}}] },
    "metricsAll":   { "params": [],                           "body": [{"op": "json", "value": {"ok": true, "execution": "micronaut-pool.metrics_all"}}] }
  }
}