{
  "class": "CodeSkillActions",
  "methods": {
    "handle": {
      "params": [],
      "body": [
        { "op": "return", "value": { "ok": true, "skill": "code_skill" } }
      ]
    },
    "read": {
      "params": ["path", "pattern"],
      "body": [
        {
          "op": "tool",
          "tool": "repo.read",
          "args": {
            "path": "$path",
            "pattern": "$pattern"
          },
          "into": "result"
        },
        {
          "op": "json",
          "value": "$result"
        },
        {
          "op": "return",
          "value": "$result"
        }
      ]
    },
    "patch": {
      "params": ["path", "find", "replace", "diff", "dryRun"],
      "body": [
        {
          "op": "tool",
          "tool": "repo.patch",
          "args": {
            "path": "$path",
            "find": "$find",
            "replace": "$replace",
            "diff": "$diff",
            "dryRun": "$dryRun"
          },
          "into": "result"
        },
        {
          "op": "json",
          "value": "$result"
        },
        {
          "op": "return",
          "value": "$result"
        }
      ]
    },
    "test": {
      "params": ["command"],
      "body": [
        {
          "op": "tool",
          "tool": "repo.test",
          "args": {
            "command": "$command"
          },
          "into": "result"
        },
        {
          "op": "json",
          "value": "$result"
        },
        {
          "op": "return",
          "value": "$result"
        }
      ]
    },
    "review": {
      "params": ["target"],
      "body": [
        {
          "op": "tool",
          "tool": "repo.review",
          "args": {
            "target": "$target"
          },
          "into": "result"
        },
        {
          "op": "json",
          "value": "$result"
        },
        {
          "op": "return",
          "value": "$result"
        }
      ]
    }
  }
}
