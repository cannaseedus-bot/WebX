<script>
// ── KuhulRuntime WebView2 Bridge ─────────────────────────────────────────────
(function(){
  function dispatchKuhul(code){
    if(window.chrome&&window.chrome.webview){
      window.chrome.webview.postMessage(JSON.stringify({type:"kuhul",code:code}));return;
    }
    const m=code.match(/⟁\s*(\w+)(.*)/);if(!m)return;
    const op=m[1];
    if(op==="DBG_STEP")  window.dbg&&window.dbg.step();
    else if(op==="DBG_RUN")   window.dbg&&window.dbg.run();
    else if(op==="DBG_PAUSE") window.dbg&&window.dbg.pause();
    else if(op==="DBG_FUSED"){
      document.querySelectorAll("[data-kuhul-click]").forEach(el=>{
        if((el.dataset.kuhulClick||"").includes("DBG_FUSED"))el.click();
      });
    }
  }
  document.addEventListener("click",function(e){
    const el=e.target.closest("[kuhul-click],[data-kuhul-click]");
    if(!el)return;
    const code=el.getAttribute("kuhul-click")||el.dataset.kuhulClick;
    if(code)dispatchKuhul(code);
  },true);
  window.KuhulDispatch=dispatchKuhul;
  if(window.chrome&&window.chrome.webview){
    window.chrome.webview.addEventListener("message",function(e){
      try{
        const msg=typeof e.data==="string"?JSON.parse(e.data):e.data;
        if(msg.type==="kuhul_ack"){
          if(msg.op==="DBG_STEP")  window.dbg&&window.dbg.step();
          else if(msg.op==="DBG_RUN")  window.dbg&&window.dbg.run();
          else if(msg.op==="DBG_PAUSE") window.dbg&&window.dbg.pause();
        } else if(msg.type==="token"){
          if(window._pchatStream&&msg.text){window._pchatStream.textContent+=msg.text;if(window._pchatHist)window._pchatHist.scrollTop=window._pchatHist.scrollHeight;}
        } else if(msg.type==="perf"){
          if(window._pchatPerf)window._pchatPerf.textContent=msg.tps.toFixed(1)+' tok/s  step '+msg.step;
        } else if(msg.type==="done"){
          window._pchatStream=null;window._pchatPerf=null;
          if(window._pchatSendBtn){window._pchatSendBtn.disabled=false;window._pchatSendBtn.textContent='SEND';}
        }
      }catch(ex){}
    });
  }
  console.log("[KuhulRuntime] bridge active — WebView2:",!!(window.chrome&&window.chrome.webview));
})();
</script>

