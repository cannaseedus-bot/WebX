        diagnostics:   {id:"diagnostics",  title:"Diagnostics",     nodeType:"runtime.diag",       group:"GPU",    icon:"🩺", desc:"System health & perf"},
        svg3d:         {id:"svg3d",         title:"SVG-3D RUNTIME", nodeType:"svgrt.core",          group:"3D",     icon:"🌐", desc:"π-geodesic vector rendering"},
        games:         {id:"games",         title:"Mini Runtimes",  nodeType:"runtime.canvas.grid", group:"3D",     icon:"🎮", desc:"Canvas kernel demos"},
