    };

    // XJSON boot AST for PRIME-IFAL v4
    const XJSON_BOOT = {
      id:"prime.ifal.v4",
      type:"os.cockpit",
      state:{ activeModule:"terminal" },
      modules:{
        primechat_full:{id:"primechat_full",title:"PRIME CHAT PRO",nodeType:"runtime.primechat",  group:"AI",     icon:"💬", desc:"Stream tokens from GPUModel bridge"},
