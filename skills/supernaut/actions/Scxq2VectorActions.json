{
  "class": "Scxq2VectorActions",
  "methods": {
    "run": {
      "params": ["bytecode"],
      "body": [
        {"op": "exec", "cmd": "scxq2_vector_runner.exe \"$bytecode\"", "result": "out"},
        {"op": "json", "value": {"ok": true, "execution": "scxq2-vector.run", "bytecode": "$bytecode", "result": "$out"}}
      ]
    }
  }
}