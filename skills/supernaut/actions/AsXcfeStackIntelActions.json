{
  "class": "AsXcfeStackIntelActions",
  "methods": {
    "diffStacks": {
      "params": ["stack_a", "stack_b"],
      "body": [
        {"op": "set", "var": "req", "value": {"stack_a": "$stack_a", "stack_b": "$stack_b"}},
        {"op": "json", "value": {"ok": true, "execution": "as-xcfe-stack-intel.diff_stacks", "stacks": "$req"}}
      ]
    },
    "listAgents": {
      "params": [],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "as-xcfe-stack-intel.list_agents"}}
      ]
    },
    "validateSync": {
      "params": ["skill"],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "as-xcfe-stack-intel.validate_sync", "skill": "$skill"}}
      ]
    },
    "reportGaps": {
      "params": ["scope"],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "as-xcfe-stack-intel.report_gaps", "scope": "$scope"}}
      ]
    },
    "syncSkill": {
      "params": ["skill", "target"],
      "body": [
        {"op": "json", "value": {"ok": true, "execution": "as-xcfe-stack-intel.sync_skill", "skill": "$skill", "target": "$target"}}
      ]
    }
  }
}