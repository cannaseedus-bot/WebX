{
  "class": "MicronautActions",
  "methods": {
    "startProject": {
      "params": ["projectName"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "baseConfig"
        },
        {
          "op": "get",
          "from": "$baseConfig",
          "path": "environment",
          "into": "baseEnvironment"
        },
        {
          "op": "get",
          "from": "$baseConfig",
          "path": "components",
          "into": "baseComponents"
        },
        {
          "op": "set",
          "var": "project",
          "value": {
            "name": "$projectName",
            "status": "initialized"
          }
        },
        {
          "op": "setProp",
          "target": "$project",
          "path": "environment",
          "value": "$baseEnvironment"
        },
        {
          "op": "setProp",
          "target": "$project",
          "path": "components",
          "value": "$baseComponents"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "project": "$project"
          }
        }
      ]
    },
    "configureEndpoint": {
      "params": ["path", "method"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "config"
        },
        {
          "op": "setProp",
          "target": "$config",
          "path": "gateway.endpoint",
          "value": "$path"
        },
        {
          "op": "setProp",
          "target": "$config",
          "path": "gateway.method",
          "value": "$method"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "gateway": "$config.gateway"
          }
        }
      ]
    },
    "secureEndpoint": {
      "params": ["role"],
      "body": [
        {
          "op": "compare",
          "opType": "eq",
          "a": "$role",
          "b": "admin",
          "into": "isAdmin"
        },
        {
          "op": "compare",
          "opType": "eq",
          "a": "$role",
          "b": "developer",
          "into": "isDeveloper"
        },
        {
          "op": "compare",
          "opType": "eq",
          "a": "$role",
          "b": "ops",
          "into": "isOps"
        },
        {
          "op": "set",
          "var": "allowed",
          "value": "$isAdmin"
        },
        {
          "op": "if",
          "cond": {
            "var": "isDeveloper"
          },
          "then": [
            {
              "op": "set",
              "var": "allowed",
              "value": true
            }
          ]
        },
        {
          "op": "if",
          "cond": {
            "var": "isOps"
          },
          "then": [
            {
              "op": "set",
              "var": "allowed",
              "value": true
            }
          ]
        },
        {
          "op": "json",
          "value": {
            "role": "$role",
            "allowed": "$allowed"
          }
        }
      ]
    },
    "injectBean": {
      "params": ["beanName"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "system"
        },
        {
          "op": "set",
          "var": "di",
          "value": "$system.components"
        },
        {
          "op": "setProp",
          "target": "$di",
          "path": "$beanName",
          "value": {
            "status": "available",
            "scope": "singleton",
            "dependencies": [
              "configuration",
              "env"
            ]
          }
        },
        {
          "op": "json",
          "value": {
            "bean": "$beanName",
            "di": "$di"
          }
        }
      ]
    },
    "scheduleTask": {
      "params": ["task", "cron"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "sched"
        },
        {
          "op": "setProp",
          "target": "$sched",
          "path": "scheduler.task",
          "value": "$task"
        },
        {
          "op": "setProp",
          "target": "$sched",
          "path": "scheduler.cron",
          "value": "$cron"
        },
        {
          "op": "json",
          "value": {
            "scheduled": "$sched.scheduler"
          }
        }
      ]
    },
    "eventBridge": {
      "params": ["topic", "payload"],
      "body": [
        {
          "op": "set",
          "var": "event",
          "value": {
            "topic": "$topic",
            "payload": "$payload",
            "status": "emitted"
          }
        },
        {
          "op": "json",
          "value": {
            "event": "$event",
            "listeners": [
              "MicronautActions.startProject",
              "MicronautActions.secureEndpoint",
              "MicronautActions.injectBean"
            ]
          }
        }
      ]
    },
    "toolDiResolve": {
      "params": ["dependency"],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.di.resolve",
              "mode": "deterministic"
            },
            "resolved": true,
            "bean": "$dependency",
            "scope": "singleton",
            "constructorChain": [
              "KnowledgeGraphService -> GraphRepository",
              "GraphRepository -> IDBClient"
            ],
            "lifecycleHooks": [
              "onStart",
              "onStop"
            ]
          }
        }
      ]
    },
    "toolDiInject": {
      "params": ["micronautId", "dependency"],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.di.inject",
              "mode": "deterministic"
            },
            "status": "injected",
            "micronautId": "$micronautId",
            "dependency": "$dependency",
            "handle": {
              "agent": "$micronautId",
              "dependency": "$dependency",
              "type": "singleton"
            }
          }
        }
      ]
    },
    "toolStateGet": {
      "params": ["micronautId"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "stateDoc"
        },
        {
          "op": "get",
          "from": "$stateDoc",
          "path": "micronautState.current",
          "into": "currentState"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.state.get",
              "mode": "deterministic"
            },
            "micronautId": "$micronautId",
            "state": "$currentState"
          }
        }
      ]
    },
    "toolStateSet": {
      "params": ["micronautId", "writes"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "stateDoc"
        },
        {
          "op": "set",
          "var": "stateEntry",
          "value": {
            "micronautId": "$micronautId",
            "writes": "$writes"
          }
        },
        {
          "op": "setProp",
          "target": "$stateDoc",
          "path": "micronautState.current",
          "value": "$stateEntry"
        },
        {
          "op": "save",
          "to": "application.json",
          "value": "$stateDoc"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.state.set",
              "mode": "deterministic"
            },
            "status": "ok",
            "tick": 1
          }
        }
      ]
    },
    "toolScheduleTask": {
      "params": ["micronautId", "task"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "schedDoc"
        },
        {
          "op": "setProp",
          "target": "$schedDoc",
          "path": "scheduler.toolTask",
          "value": "$task"
        },
        {
          "op": "save",
          "to": "application.json",
          "value": "$schedDoc"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.schedule.task",
              "mode": "deterministic"
            },
            "scheduled": true,
            "micronautId": "$micronautId",
            "task": "$task",
            "taskId": "task-1",
            "nextRun": "deterministic-next-run"
          }
        }
      ]
    },
    "toolEventEmit": {
      "params": ["micronautId", "event"],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.event.emit",
              "mode": "deterministic"
            },
            "status": "delivered",
            "micronautId": "$micronautId",
            "event": "$event",
            "handlersInvoked": [
              "onLearningCompleted"
            ]
          }
        }
      ]
    },
    "toolRuntimeStep": {
      "params": ["micronautId"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "runtimeDoc"
        },
        {
          "op": "get",
          "from": "$runtimeDoc",
          "path": "runtime.tick",
          "into": "currentTick"
        },
        {
          "op": "set",
          "var": "nextTick",
          "value": 1
        },
        {
          "op": "if",
          "cond": {
            "var": "currentTick"
          },
          "then": [
            {
              "op": "add",
              "a": "$currentTick",
              "b": 1,
              "into": "nextTick"
            }
          ]
        },
        {
          "op": "setProp",
          "target": "$runtimeDoc",
          "path": "runtime.tick",
          "value": "$nextTick"
        },
        {
          "op": "save",
          "to": "application.json",
          "value": "$runtimeDoc"
        },
        {
          "op": "tool",
          "tool": "model.dispatch",
          "args": {
            "mode": "hybrid",
            "backend": "manifest"
          },
          "into": "miniModelSummary"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.runtime.step",
              "mode": "deterministic"
            },
            "miniModel": "$miniModelSummary",
            "tick": "$nextTick",
            "actions": [
              {
                "type": "emit",
                "event": "goal.progress",
                "payload": {
                  "micronautId": "$micronautId"
                }
              }
            ]
          }
        }
      ]
    },
    "toolRuntimeRun": {
      "params": ["micronautId", "maxTicks"],
      "body": [
        {
          "op": "load",
          "from": "application.json",
          "into": "runtimeDoc"
        },
        {
          "op": "get",
          "from": "$runtimeDoc",
          "path": "runtime.tick",
          "into": "currentTick"
        },
        {
          "op": "set",
          "var": "baseTick",
          "value": 0
        },
        {
          "op": "if",
          "cond": {
            "var": "currentTick"
          },
          "then": [
            {
              "op": "set",
              "var": "baseTick",
              "value": "$currentTick"
            }
          ]
        },
        {
          "op": "set",
          "var": "ticksToRun",
          "value": 1
        },
        {
          "op": "if",
          "cond": {
            "var": "maxTicks"
          },
          "then": [
            {
              "op": "set",
              "var": "ticksToRun",
              "value": "$maxTicks"
            }
          ]
        },
        {
          "op": "add",
          "a": "$baseTick",
          "b": "$ticksToRun",
          "into": "finalTick"
        },
        {
          "op": "setProp",
          "target": "$runtimeDoc",
          "path": "runtime.tick",
          "value": "$finalTick"
        },
        {
          "op": "save",
          "to": "application.json",
          "value": "$runtimeDoc"
        },
        {
          "op": "tool",
          "tool": "model.dispatch",
          "args": {
            "mode": "hybrid",
            "backend": "manifest"
          },
          "into": "miniModelSummary"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.runtime.run",
              "mode": "deterministic"
            },
            "miniModel": "$miniModelSummary",
            "status": "completed",
            "ticks": "$ticksToRun",
            "finalState": {
              "micronautId": "$micronautId",
              "tick": "$finalTick"
            }
          }
        }
      ]
    },
    "toolClusterMigrate": {
      "params": ["micronautId", "targetNode"],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.cluster.migrate",
              "mode": "deterministic"
            },
            "status": "migrated",
            "micronautId": "$micronautId",
            "node": "$targetNode"
          }
        }
      ]
    },
    "toolClusterReplicate": {
      "params": ["micronautId", "mode"],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "micronaut.cluster.replicate",
              "mode": "deterministic"
            },
            "status": "replicated",
            "newId": "$micronautId",
            "replicationMode": "$mode"
          }
        }
      ]
    }
  }
}
