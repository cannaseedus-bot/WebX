      makeGalactica(){
        const cvs=document.createElement("canvas");
        cvs.width=640;cvs.height=220;
        const ctx=cvs.getContext("2d");
        const W=cvs.width,H=cvs.height;
        const state={t:0,last:performance.now(),bul:[],en:[],score:0,px:W/2,cd:0,auto:true};
        for(let i=0;i<10;i++) state.en.push({x:60+i*50,y:80+(i%2)*20,v:50+Math.random()*50});
        (function step(now){
          requestAnimationFrame(step);
          const dt=Math.min(.033,(now-(state.last||now))/1000);
          state.last=now;state.t+=dt;state.cd-=dt;
          if(state.auto && state.cd<=0){
            state.bul.push({x:state.px,y:H-30,v:-300});
            state.cd=.18;
          }
          state.en.forEach(e=>{e.x+=Math.sin(state.t*e.v/50)*.6;});
          state.bul.forEach(b=>b.y+=b.v*dt);
          for(const b of state.bul){
            for(const e of state.en){
              if(Math.abs(b.x-e.x)<14 && Math.abs(b.y-e.y)<12){
                b.hit=true;e.hit=true;state.score+=50;
              }
            }
          }
          state.en=state.en.filter(e=>!e.hit);
          state.bul=state.bul.filter(b=>!b.hit && b.y>-40);

          ctx.fillStyle="#030b12";ctx.fillRect(0,0,W,H);
          ctx.fillStyle="rgba(255,255,255,.35)";
          for(let i=0;i<80;i++){
            const sx=(i*97%W);const sy=(i*53*7+(state.t*60*i))%H;
            ctx.fillRect(sx,sy,2,2);
          }
          ctx.fillStyle="#9ff";
          ctx.beginPath();
          ctx.moveTo(state.px,H-50);
          ctx.lineTo(state.px+12,H-20);
          ctx.lineTo(state.px-12,H-20);
          ctx.closePath();ctx.fill();
          ctx.fillStyle="#ffd37f";
          state.en.forEach(e=>ctx.fillRect(e.x-10,e.y-8,20,16));
          ctx.fillStyle="#fff";
          state.bul.forEach(b=>ctx.fillRect(b.x-2,b.y-6,4,12));
          ctx.fillStyle="#0fa";ctx.font="12px monospace";
          ctx.fillText("Score "+state.score,10,18);
        })(performance.now());
        return this.makeCard("Galactica",cvs);
      }

      makeInvaders(){
