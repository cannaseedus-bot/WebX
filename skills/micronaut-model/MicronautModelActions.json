  "xjson_format": {
    "summary": "Complete @-key semantics for atomic_block_fold micronaut format.",
    "top_level_sections": {
      "@meta": "Identity, version, format declaration — all IMMUTABLE",
      "@lanes": "5 named data buses: agent(0), skills(1), experts(2), runtime(3), router(4)",
      "@phases": "4-phase cycle: Pop(load) → Wo(resolve) → Sek(execute) → Ch'en(update)",
      "@variables": "MUTABLE (routing_bias, learned, memory) and IMMUTABLE (model, experts) variable schemas",
      "@edges": "Signal routing topology: skill→expert edges + router→experts dispatch + experts→learned feedback (CRITICAL)",
      "@agent.main": "Primary cognitive block (lane 0, phase Pop): persona, system_prompt, learned_biases, memory",
      "@model.core": "Backend weight declaration with @xcfe:IMMUTABLE — see backends",
      "@runtime.gpu": "Hardware abstraction (lane 3): d3d12/metal/vulkan backend, condition_exports",
      "@moe.router": "Expert router (lane 4, implicit kernel): top_k_experts=2, persist_learning, state_file",
      "@skills": "Skill trigger definitions (lane 1): trigger phrases → routes_to experts",
      "@experts": "Expert compute endpoints (lane 2): domain, routing_bias=0.0, dispatch_signal",
      "@backend": "HTTP endpoint block — ONLY for api_* backends"
    },
    "id_conventions": {
      "micronaut_id": "[A-Z]{2,3}-[0-9]+ (e.g. CM-1, SM-2, RM-3)",
      "block_id": "<type>-<name> kebab-case (e.g. agent-main, expert-code)",
      "dispatch_signal": "<verb>_<noun> snake_case (e.g. summarize_text)",
      "state_file": "models/<ID>_state.bson"
    },
    "critical_rules": [
      "experts→learned feedback edge MUST always be present",
      "routing_bias MUST be 0.0 for new experts",
      "@model.core.@xcfe MUST be IMMUTABLE",
      "api_* backends MUST have @backend block; local backends MUST NOT"
    ],
    "reference_file": "~/.codex/skills/micronaut-model/references/xjson-format.md"
  },

  "native_bridge": {
    "summary": "Pure-Python bridge mirroring the two C++ headers. Co-located with every scaffolded bots.py.",
    "source": "assets/micronaut_native.py",
    "classes": {
      "TodoItem": {
        "mirrors": "micronaut_todo_creator.hpp :: struct TodoItem",
        "fields": ["id", "title", "description", "category", "priority (1-5)", "service", "line_number", "confidence", "status", "depends_on"]
      },
      "TodoCreator": {
        "mirrors": "micronaut_todo_creator.hpp :: class TodoCreator",
        "key_methods": [
          "extract_todos(content) → list[TodoItem]",
          "extract_todo_comments(content) → list[TodoItem]",
          "extract_fixme_comments(content) → list[TodoItem]",
          "extract_hack_comments(content) → list[TodoItem]",
          "extract_issue_patterns(content) → list[TodoItem]",
          "extract_from_configuration(content) → list[TodoItem]",
          "assess_priority(marker, comment) → int",
          "generate_todo_id(item, line) → str"
        ]
      },
      "TodoJsonSerializer": {
        "mirrors": "micronaut_todo_creator.hpp :: class TodoJsonSerializer",
        "key_methods": [
          "to_json(todo) → str",
          "to_json_array(todos) → str  ← V6 format with @version, @format, total",
          "to_html_dashboard(todos) → str  ← dark theme, priority color classes p1-p5",
          "to_markdown(todos) → str  ← markdown table"
        ]
      },
      "DeterministicV6": {
        "mirrors": "deterministic_v6.h :: class DeterministicV6",
        "key_methods": [
          "sha256(input) → bytes",
          "sha256_hex(input) → str",
          "json_canonical(json_str) → str  ← lexicographic key sort",
          "parse_canonical(json_str) → dict",
          "iso8601_now() → str  ← UTC ISO 8601",
          "create_tool_result(tool_name, input_hash, output_hash, result, latency_ms, status) → str  ← V6 JSON"
        ]
      },
      "TraceLogger": {
        "mirrors": "deterministic_v6.h :: class TraceLogger",
        "key_methods": [
          "log_tool_execution(tool_name, input, output, latency_ms, status) → None",
          "flush() → None  ← JSONL append to trace file",
          "__del__() → flush guard"
        ],
        "behavior": "auto-flushes when pending entries >= 10"
      }
    },
    "NATIVE_AVAILABLE": "bool flag — True if compiled native DLL/SO found in build/",
    "scaffold_integration": "scaffold_micronaut.py new copies this file alongside every generated bots.py",
    "usage_in_bots_py": "sys.path.insert(0, str(Path(__file__).parent)); from micronaut_native import ..."
  },

  "fold_map": {
    "summary": "Fold → micronaut ID mapping, HLSL entry points, and _MICRONAUT_TO_FOLD Python dict.",
    "folds": {
      "CONTROL": { "symbol": "⟁CONTROL_FOLD⟁", "lane": 0, "hlsl_entry": "CS_ControlFold", "canonical_id": "CM-1", "role": "orchestration, routing, plan execution" },
      "DATA":    { "symbol": "⟁DATA_FOLD⟁",    "lane": 1, "hlsl_entry": "CS_DataFold",    "canonical_id": "PM-1", "role": "data pipeline, dataset discovery, SQL" },
      "TIME":    { "symbol": "⟁TIME_FOLD⟁",    "lane": 2, "hlsl_entry": "CS_TimeFold",    "canonical_id": "TM-1", "role": "scheduling, temporal reasoning" },
      "STATE":   { "symbol": "⟁STATE_FOLD⟁",   "lane": 3, "hlsl_entry": "CS_StateFold",   "canonical_id": "HM-1", "role": "session state, memory, history" },
      "STORAGE": { "symbol": "⟁STORAGE_FOLD⟁", "lane": 4, "hlsl_entry": "CS_StorageFold", "canonical_id": "SM-1", "role": "file I/O, persistence, retrieval" },
      "COMPUTE": { "symbol": "⟁COMPUTE_FOLD⟁", "lane": 5, "hlsl_entry": "CS_ComputeFold", "canonical_id": "MM-1", "role": "code, math, inference, computation" },
      "PATTERN": { "symbol": "⟁PATTERN_FOLD⟁", "lane": 6, "hlsl_entry": "CS_PatternFold", "canonical_id": "XM-1", "role": "pattern matching, reasoning, chain-of-thought" },
      "UI":      { "symbol": "⟁UI_FOLD⟁",      "lane": 7, "hlsl_entry": "CS_UIFold",      "canonical_id": "VM-1", "role": "UI rendering, visualization, output formatting" },
      "META":    { "symbol": "⟁META_FOLD⟁",    "lane": 8, "hlsl_entry": "CS_MetaFold",    "canonical_id": "VM-2", "role": "self-evaluation, meta-reasoning, orchestration" }
    },
    "orchestrator_bot_dict": {
      "file": "micronaut/src/orchestrator_bot.py",
      "dict_name": "_MICRONAUT_TO_FOLD",
      "existing_entries": {
        "CM-1": "⟁CONTROL_FOLD⟁",
        "PM-1": "⟁DATA_FOLD⟁",
        "TM-1": "⟁TIME_FOLD⟁",
        "HM-1": "⟁STATE_FOLD⟁",
        "SM-1": "⟁STORAGE_FOLD⟁",
        "MM-1": "⟁COMPUTE_FOLD⟁",
        "XM-1": "⟁PATTERN_FOLD⟁",
        "VM-1": "⟁UI_FOLD⟁",
        "VM-2": "⟁META_FOLD⟁"
      },
      "note": "Add your new micronaut ID here after scaffolding"
    },
    "fold_for_backend": {
      "reasoning_cot": "PATTERN",
      "code_math": "COMPUTE",
      "data_sql": "DATA",
      "ui_visualization": "UI",
      "orchestration": "CONTROL",
      "file_storage": "STORAGE",
      "session_memory": "STATE",
      "meta_evaluation": "META",
      "scheduling": "TIME"
    }
  }
}
