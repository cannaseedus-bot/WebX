{
  "class": "DxMathActions",
  "description": "DirectXMath-backed deterministic compute actions. Implements the three SK+DirectXMath fusion patterns: native plugin call (Pattern 1), Math-IR compiler (Pattern 2), multi-backend orchestration (Pattern 3).",
  "methods": {
    "eval_ir": {
      "params": ["irJson"],
      "body": [
        {
          "op": "set",
          "var": "result",
          "value": {
            "irJson": "$irJson",
            "backend": "dxmath_ir.dll",
            "entrypoint": "EvaluateMathIR",
            "status": "dispatched"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.eval_ir",
            "result": "$result"
          }
        }
      ]
    },
    "select_backend": {
      "params": ["batchSize", "gpuAvailable", "warpAvailable"],
      "body": [
        {
          "op": "set",
          "var": "backend",
          "value": "scalar"
        },
        {
          "op": "if",
          "cond": { "var": "warpAvailable" },
          "then": [{ "op": "set", "var": "backend", "value": "warp" }]
        },
        {
          "op": "if",
          "cond": { "var": "gpuAvailable" },
          "then": [{ "op": "set", "var": "backend", "value": "d3d12" }]
        },
        {
          "op": "if",
          "cond": { "lt": [{ "var": "batchSize" }, 1024] },
          "then": [{ "op": "set", "var": "backend", "value": "ppl" }]
        },
        {
          "op": "if",
          "cond": { "lt": [{ "var": "batchSize" }, 4] },
          "then": [{ "op": "set", "var": "backend", "value": "dxmath" }]
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.select_backend",
            "backend": "$backend",
            "routing": {
              "batchSize": "$batchSize",
              "gpuAvailable": "$gpuAvailable",
              "warpAvailable": "$warpAvailable",
              "legend": {
                "dxmath": "CPU SIMD via DirectXMath (batch < 4)",
                "ppl":    "CPU parallel PPL (batch < 1024)",
                "d3d12":  "D3D12 compute shader (GPU, batch >= 1024)",
                "warp":   "WARP software rasterizer (GPU unavailable)",
                "scalar": "Scalar fallback (WARP unavailable)"
              }
            }
          }
        }
      ]
    },
    "lattice_node": {
      "params": ["vecA", "vecB"],
      "body": [
        {
          "op": "set",
          "var": "ir",
          "value": {
            "version": "1.0",
            "graphId": "lattice-node",
            "nodes": [
              { "id": "a",    "type": "const.vec3", "value": "$vecA" },
              { "id": "b",    "type": "const.vec3", "value": "$vecB" },
              { "id": "na",   "type": "op.normalize", "input": "a" },
              { "id": "nb",   "type": "op.normalize", "input": "b" },
              { "id": "out",  "type": "op.add", "input": "na", "inputB": "nb" }
            ],
            "outputs": ["out"]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.lattice_node",
            "ir": "$ir",
            "note": "normalize(a) + normalize(b) — canonical trig-brain lattice update"
          }
        }
      ]
    },
    "rotate": {
      "params": ["vec", "axis", "angleDeg"],
      "body": [
        {
          "op": "set",
          "var": "ir",
          "value": {
            "version": "1.0",
            "graphId": "op-rotate",
            "nodes": [
              { "id": "v",   "type": "const.vec3", "value": "$vec" },
              { "id": "out", "type": "op.rotate",  "input": "v", "axis": "$axis", "angleDeg": "$angleDeg" }
            ],
            "outputs": ["out"]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.rotate",
            "ir": "$ir"
          }
        }
      ]
    },
    "normalize": {
      "params": ["vec"],
      "body": [
        {
          "op": "set",
          "var": "ir",
          "value": {
            "version": "1.0",
            "graphId": "op-normalize",
            "nodes": [
              { "id": "v",   "type": "const.vec3",   "value": "$vec" },
              { "id": "out", "type": "op.normalize", "input": "v" }
            ],
            "outputs": ["out"]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.normalize",
            "ir": "$ir"
          }
        }
      ]
    },
    "transform": {
      "params": ["vec", "matrix"],
      "body": [
        {
          "op": "set",
          "var": "ir",
          "value": {
            "version": "1.0",
            "graphId": "op-transform",
            "nodes": [
              { "id": "v",   "type": "const.vec3",    "value": "$vec" },
              { "id": "m",   "type": "const.mat4x4",  "value": "$matrix" },
              { "id": "out", "type": "op.transform",  "input": "v", "matrix": "m" }
            ],
            "outputs": ["out"]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.transform",
            "ir": "$ir"
          }
        }
      ]
    },
    "dot": {
      "params": ["vecA", "vecB"],
      "body": [
        {
          "op": "set",
          "var": "ir",
          "value": {
            "version": "1.0",
            "graphId": "op-dot",
            "nodes": [
              { "id": "a",   "type": "const.vec3", "value": "$vecA" },
              { "id": "b",   "type": "const.vec3", "value": "$vecB" },
              { "id": "out", "type": "op.dot",     "input": "a", "inputB": "b" }
            ],
            "outputs": ["out"]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.dot",
            "ir": "$ir"
          }
        }
      ]
    },
    "cross": {
      "params": ["vecA", "vecB"],
      "body": [
        {
          "op": "set",
          "var": "ir",
          "value": {
            "version": "1.0",
            "graphId": "op-cross",
            "nodes": [
              { "id": "a",   "type": "const.vec3", "value": "$vecA" },
              { "id": "b",   "type": "const.vec3", "value": "$vecB" },
              { "id": "out", "type": "op.cross",   "input": "a", "inputB": "b" }
            ],
            "outputs": ["out"]
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": "dxmath.cross",
            "ir": "$ir"
          }
        }
      ]
    }
  }
}
