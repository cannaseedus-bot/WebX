{
  "class": "SqlActions",
  "methods": {
    "connect": {
      "params": [
        "provider",
        "database"
      ],
      "body": [
        {
          "op": "load",
          "from": "sql_profiles.json",
          "into": "profiles"
        },
        {
          "op": "find",
          "array": "$profiles.providers",
          "where": {
            "name": "$provider"
          },
          "into": "selected"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sql.connect",
              "mode": "deterministic"
            },
            "provider": "$provider",
            "database": "$database",
            "profile": "$selected"
          }
        }
      ]
    },
    "listTables": {
      "params": [
        "provider"
      ],
      "body": [
        {
          "op": "load",
          "from": "sql_profiles.json",
          "into": "profiles"
        },
        {
          "op": "find",
          "array": "$profiles.providers",
          "where": {
            "name": "$provider"
          },
          "into": "selected"
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sql.tables",
              "mode": "deterministic"
            },
            "provider": "$provider",
            "tables": "$selected.tables"
          }
        }
      ]
    },
    "describeTable": {
      "params": [
        "provider",
        "table"
      ],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sql.schema",
              "mode": "deterministic"
            },
            "provider": "$provider",
            "table": "$table",
            "columns": [
              {
                "name": "id",
                "type": "integer",
                "nullable": false
              },
              {
                "name": "name",
                "type": "text",
                "nullable": false
              },
              {
                "name": "updated_at",
                "type": "datetime",
                "nullable": true
              }
            ]
          }
        }
      ]
    },
    "query": {
      "params": [
        "provider",
        "sql",
        "params"
      ],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sql.query",
              "mode": "deterministic"
            },
            "provider": "$provider",
            "sql": "$sql",
            "params": "$params",
            "rows": [
              {
                "id": 1,
                "name": "deterministic-row"
              }
            ],
            "rowCount": 1
          }
        }
      ]
    },
    "upsert": {
      "params": [
        "provider",
        "table",
        "record"
      ],
      "body": [
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "sql.upsert",
              "mode": "deterministic"
            },
            "provider": "$provider",
            "table": "$table",
            "record": "$record",
            "status": "applied",
            "affectedRows": 1
          }
        }
      ]
    }
  }
}
