{
  "class": "FigmaActions",
  "methods": {
    "get_file": {
      "params": ["fileKey"],
      "body": [
        {
          "op": "set",
          "var": "fileCtx",
          "value": {
            "fileKey": "$fileKey",
            "status": "fetched"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma.get_file",
              "mode": "deterministic"
            },
            "file": "$fileCtx"
          }
        }
      ]
    },
    "export_assets": {
      "params": ["fileKey", "nodeIds", "format"],
      "body": [
        {
          "op": "set",
          "var": "exportCtx",
          "value": {
            "fileKey": "$fileKey",
            "nodeIds": "$nodeIds",
            "format": "$format",
            "status": "exported"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma.export_assets",
              "mode": "deterministic"
            },
            "export": "$exportCtx",
            "urls": []
          }
        }
      ]
    },
    "list_components": {
      "params": ["fileKey"],
      "body": [
        {
          "op": "set",
          "var": "compCtx",
          "value": {
            "fileKey": "$fileKey",
            "status": "listed"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma.list_components",
              "mode": "deterministic"
            },
            "components": []
          }
        }
      ]
    },
    "get_tokens": {
      "params": ["fileKey"],
      "body": [
        {
          "op": "set",
          "var": "tokenCtx",
          "value": {
            "fileKey": "$fileKey",
            "status": "fetched"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma.get_tokens",
              "mode": "deterministic"
            },
            "tokens": {
              "colors": [],
              "typography": [],
              "spacing": []
            }
          }
        }
      ]
    },
    "inspect_frame": {
      "params": ["fileKey", "nodeId"],
      "body": [
        {
          "op": "set",
          "var": "frameCtx",
          "value": {
            "fileKey": "$fileKey",
            "nodeId": "$nodeId",
            "status": "inspected"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma.inspect_frame",
              "mode": "deterministic"
            },
            "frame": "$frameCtx"
          }
        }
      ]
    },
    "get_styles": {
      "params": ["fileKey"],
      "body": [
        {
          "op": "set",
          "var": "stylesCtx",
          "value": {
            "fileKey": "$fileKey",
            "status": "fetched"
          }
        },
        {
          "op": "json",
          "value": {
            "ok": true,
            "execution": {
              "tool": "figma.get_styles",
              "mode": "deterministic"
            },
            "styles": {
              "fill": [],
              "text": [],
              "effect": [],
              "grid": []
            }
          }
        }
      ]
    }
  }
}
