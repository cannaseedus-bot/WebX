{
  "providers": [
    {
      "name": "sqlite",
      "driver": "sqlite3",
      "database": "app.db",
      "tables": [
        "users",
        "tasks",
        "events"
      ]
    },
    {
      "name": "sqlserver",
      "driver": "mssql",
      "server": "127.0.0.1",
      "database": "app",
      "tables": [
        "dbo.Users",
        "dbo.Tasks",
        "dbo.Events"
      ]
    }
  ]
}
