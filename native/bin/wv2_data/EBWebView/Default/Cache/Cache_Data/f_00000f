          wrap.style.cssText="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:14px;";
          content.appendChild(wrap);

          wrap.appendChild(lbl("DEPENDENCY RESOLVER — topological sort"));

          // plugin selector
          const sel=document.createElement("div");sel.style.cssText="display:flex;gap:8px;align-items:center;flex-wrap:wrap;";
          const selLbl=document.createElement("span");selLbl.style.cssText="color:#888;font-size:10px;";selLbl.textContent="Resolve:";
          sel.appendChild(selLbl);
          PLUGINS.forEach(p=>{
            const btn=mkBtn(p.id,'#555',()=>doResolve(p),true);
            sel.appendChild(btn);
          });
          wrap.appendChild(sel);

          const resultArea=document.createElement("div");resultArea.style.cssText="display:flex;flex-direction:column;gap:10px;";
          wrap.appendChild(resultArea);

          function doResolve(plugin){
            resultArea.innerHTML="";
            window.KernelTrace&&window.KernelTrace.emit('PLUGIN_RESOLVE',{id:plugin.id});

            // topo sort
            const visited=new Set(),order=[];
            function visit(id){
              if(visited.has(id))return;visited.add(id);
              const p=PLUGINS.find(x=>x.id===id);
              if(p)p.depends.forEach(visit);
              order.push(id);
            }
            visit(plugin.id);

            resultArea.appendChild(lbl(`RESOLUTION ORDER for ${plugin.id}`));
            const steps=document.createElement("div");steps.style.cssText="display:flex;flex-direction:column;gap:4px;";
            order.forEach((id,i)=>{
              const p=PLUGINS.find(x=>x.id===id);
              const row=document.createElement("div");
              row.style.cssText="display:flex;align-items:center;gap:10px;padding:7px 12px;background:#12121c;border:1px solid #1e1e30;border-radius:4px;font-family:monospace;font-size:10px;";
