{
  "class": "DolphinCoderActions",
  "methods": {
    "handle": {
      "params": [],
      "body": [
        {
          "op": "return",
          "value": {
            "ok": true,
            "skill": "dolphin_coder_skill",
            "provider": "dolphin",
            "model": "dolphin-coder"
          }
        }
      ]
    },
    "catalog": {
      "params": ["includeLineCounts"],
      "body": [
        {
          "op": "tool",
          "tool": "dataset.catalog",
          "args": {
            "includeLineCounts": "$includeLineCounts"
          },
          "into": "result"
        },
        {
          "op": "json",
          "value": "$result"
        },
        {
          "op": "return",
          "value": "$result"
        }
      ]
    },
    "refinePlan": {
      "params": ["source", "trainRatio", "shuffleSeed", "maxSamples", "trainOut", "valOut"],
      "body": [
        {
          "op": "tool",
          "tool": "dataset.refine_plan",
          "args": {
            "source": "$source",
            "trainRatio": "$trainRatio",
            "shuffleSeed": "$shuffleSeed",
            "maxSamples": "$maxSamples",
            "trainOut": "$trainOut",
            "valOut": "$valOut"
          },
          "into": "result"
        },
        {
          "op": "json",
          "value": "$result"
        },
        {
          "op": "return",
          "value": "$result"
        }
      ]
    }
  }
}

