[
  {
    "name": "arbitrate",
    "class": "AgenticMicronautActions",
    "method": "arbitrate",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Arbitrate between multiple agent decisions using consensus, weighted, or priority tiebreaking",
    "parameters": {
      "decisions": { "type": "array", "items": { "type": "object" } },
      "context": { "type": "object" },
      "tiebreaker": { "type": "string", "enum": ["consensus", "weighted", "priority"], "default": "consensus" }
    },
    "operations": [
      { "op": "LOAD_CONTEXT", "from": "context" },
      { "op": "CONSENSUS_AGGREGATE", "items": "decisions" },
      { "op": "APPLY_TIEBREAKER", "rule": "tiebreaker" },
      { "op": "EMIT_EVENT", "event": "decision.arbitrated" },
      { "op": "RETURN_DECISION", "schema": "decision_result" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "decision": { "type": "object" },
      "rationale": { "type": "string" },
      "confidence": { "type": "number" }
    }
  },
  {
    "name": "project_skill",
    "class": "AgenticMicronautActions",
    "method": "project_skill",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Project skill from source format into Micronaut-style runtime (TOML, manifest, actions)",
    "parameters": {
      "skill_name": { "type": "string" },
      "source_format": { "type": "string", "enum": ["markdown", "json", "yaml"] },
      "target_runtime": { "type": "string", "default": "xcfe" }
    },
    "operations": [
      { "op": "PARSE_SKILL", "format": "source_format" },
      { "op": "EXTRACT_ROUTES", "from": "parsed_skill" },
      { "op": "EXTRACT_ACTIONS", "from": "parsed_skill" },
      { "op": "GENERATE_TOML", "runtime": "target_runtime" },
      { "op": "GENERATE_MANIFEST", "version": "1.0.0" },
      { "op": "VALIDATE_PARITY", "routes_count": "routes", "actions_count": "actions" },
      { "op": "RETURN_PROJECTION", "format": "object" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "projected_skill": { "type": "object" },
      "routes": { "type": "object" },
      "actions": { "type": "array" }
    }
  },
  {
    "name": "resolve_agent",
    "class": "AgenticMicronautActions",
    "method": "resolve_agent",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Resolve agent configuration with deterministic dependency resolution",
    "parameters": {
      "agent_id": { "type": "string" },
      "dependencies": { "type": "array", "items": { "type": "string" } }
    },
    "operations": [
      { "op": "LOAD_AGENT_CONFIG", "agent_id": "agent_id" },
      { "op": "TRACE_DEPENDENCIES", "deps": "dependencies" },
      { "op": "RESOLVE_CONSTRUCTOR_CHAIN", "depth_limit": 10 },
      { "op": "VALIDATE_RESOLUTION", "check_cycles": true },
      { "op": "EMIT_EVENT", "event": "agent.resolved" },
      { "op": "RETURN_RESOLVED", "with_execution_plan": true }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "resolved": { "type": "object" },
      "execution": { "type": "object" }
    }
  },
  {
    "name": "list_registry",
    "class": "AgenticMicronautActions",
    "method": "list_registry",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "List all registered models, skills, and agents in the registry",
    "parameters": {
      "filter": { "type": "string", "default": "" }
    },
    "operations": [
      { "op": "LOAD_REGISTRY", "source": "micronaut-registry.json" },
      { "op": "LIST_MODELS", "filter": "filter" },
      { "op": "LIST_SKILLS", "filter": "filter" },
      { "op": "LIST_AGENTS", "filter": "filter" },
      { "op": "SORT_BY_NAME", "ascending": true },
      { "op": "RETURN_REGISTRY" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "models": { "type": "array" },
      "skills": { "type": "array" },
      "agents": { "type": "array" }
    }
  },
  {
    "name": "pack_shard",
    "class": "AgenticMicronautActions",
    "method": "pack_shard",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Pack agent into deployable shard (SCXQDDS, SCXQ7, or XSHARD)",
    "parameters": {
      "agent_id": { "type": "string" },
      "format": { "type": "string", "enum": ["scxqdds", "scxq7", "xshard"] }
    },
    "operations": [
      { "op": "LOAD_AGENT_DATA", "agent_id": "agent_id" },
      { "op": "COMPRESS", "format": "format" },
      { "op": "WRITE_SHARD", "dest": "artifacts/" },
      { "op": "COMPUTE_CRC", "verify": true },
      { "op": "EMIT_EVENT", "event": "shard.packed" },
      { "op": "RETURN_SHARD_INFO" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "shard_path": { "type": "string" },
      "size": { "type": "number" },
      "compression_ratio": { "type": "number" }
    }
  },
  {
    "name": "wire_fleet_agent",
    "class": "AgenticMicronautActions",
    "method": "wire_fleet_agent",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Wire Fleet agent to SK-1 skills and Micronaut runtime actions",
    "parameters": {
      "agent_name": { "type": "string", "enum": ["planner", "executor", "coordinator", "responder", "diagnostician"] },
      "skills": { "type": "array", "items": { "type": "string" } },
      "micronaut_actions": { "type": "array", "items": { "type": "string" } }
    },
    "operations": [
      { "op": "LOAD_AGENT_DEFINITION", "name": "agent_name" },
      { "op": "BIND_SK_SKILLS", "skills": "skills" },
      { "op": "BIND_MICRONAUT_ACTIONS", "actions": "micronaut_actions" },
      { "op": "VALIDATE_SKILL_SIGNATURES", "check_arity": true },
      { "op": "EMIT_EVENT", "event": "agent.wired" },
      { "op": "RETURN_WIRED_AGENT" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "wired_agent": { "type": "object" },
      "skills_bound": { "type": "number" },
      "actions_bound": { "type": "number" }
    }
  },
  {
    "name": "configure_agent_pipeline",
    "class": "AgenticMicronautActions",
    "method": "configure_agent_pipeline",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Configure multi-agent pipeline with routing and fallback chains",
    "parameters": {
      "agents": { "type": "array", "items": { "type": "string" } },
      "routing": { "type": "object" },
      "fallback_chain": { "type": "array", "items": { "type": "string" } }
    },
    "operations": [
      { "op": "LOAD_AGENTS", "ids": "agents" },
      { "op": "CONFIGURE_ROUTING", "rules": "routing" },
      { "op": "REGISTER_FALLBACK_CHAIN", "chain": "fallback_chain" },
      { "op": "VALIDATE_PIPELINE", "check_cycles": true },
      { "op": "EMIT_EVENT", "event": "pipeline.configured" },
      { "op": "RETURN_PIPELINE_CONFIG" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "pipeline": { "type": "object" },
      "routes_registered": { "type": "number" }
    }
  },
  {
    "name": "emit_agent_event",
    "class": "AgenticMicronautActions",
    "method": "emit_agent_event",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Emit event to coordinate agents across the fleet",
    "parameters": {
      "event_type": { "type": "string" },
      "payload": { "type": "object" },
      "targets": { "type": "array", "items": { "type": "string" } }
    },
    "operations": [
      { "op": "VALIDATE_EVENT", "schema": "event_type" },
      { "op": "LOAD_LISTENERS", "targets": "targets" },
      { "op": "EMIT", "event": "event_type", "data": "payload" },
      { "op": "TRACK_DELIVERY", "log_failures": true },
      { "op": "EMIT_ACK", "event": "event.emitted" },
      { "op": "RETURN_EVENT_RESULT" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "event_id": { "type": "string" },
      "listeners_triggered": { "type": "number" }
    }
  },
  {
    "name": "validate_agent_contract",
    "class": "AgenticMicronautActions",
    "method": "validate_agent_contract",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Validate agent contract and action/route/intent parity",
    "parameters": {
      "agent_id": { "type": "string" }
    },
    "operations": [
      { "op": "LOAD_AGENT_CONFIG", "agent_id": "agent_id" },
      { "op": "CHECK_ROUTE_TARGETS", "in": "actions" },
      { "op": "CHECK_INTENT_ROUTES", "in": "manifest" },
      { "op": "CHECK_ACTION_CLASSES", "in": "impl" },
      { "op": "COLLECT_ISSUES", "strict": true },
      { "op": "EMIT_VALIDATION_RESULT", "event": "contract.validated" },
      { "op": "RETURN_VALIDATION" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "contract_valid": { "type": "boolean" },
      "issues": { "type": "array" },
      "action_parity": { "type": "object" }
    }
  },
  {
    "name": "export_agent_definition",
    "class": "AgenticMicronautActions",
    "method": "export_agent_definition",
    "runtime": "xcfe",
    "deterministic": true,
    "description": "Export agent definition for sharing or deployment",
    "parameters": {
      "agent_id": { "type": "string" },
      "format": { "type": "string", "enum": ["json", "yaml", "markdown"] }
    },
    "operations": [
      { "op": "LOAD_AGENT_CONFIG", "agent_id": "agent_id" },
      { "op": "EXPORT_AS", "format": "format" },
      { "op": "WRITE_FILE", "dest": "exports/" },
      { "op": "COMPUTE_HASH", "file": "exported" },
      { "op": "EMIT_EVENT", "event": "agent.exported" },
      { "op": "RETURN_EXPORT_PATH" }
    ],
    "returns": {
      "ok": { "type": "boolean" },
      "definition": { "type": "object" },
      "export_path": { "type": "string" }
    }
  }
]
