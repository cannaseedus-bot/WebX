@@class.control
  @name: "supernaut_flow"

  meta
    name: "Supernaut Flow"
    domain: "codex"
    authority: "bounded"

  vectors
    control: ["@load", "@route", "@dispatch", "@merge", "@validate", "@report"]
    variable: ["@skill", "@route", "@manifest", "@intent"]
    flow: ["@next", "@accept", "@reject"]

  invariants
    - "Supernaut flow must preserve route-to-intent determinism"
    - "Merged skill imports must resolve through a single manifest surface"
    - "Code aliases must remain bound to the code skill surface"
