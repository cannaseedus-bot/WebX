{
  "_comment": "Glyph Opcode System — unified 1024-token vocabulary for language + compute + tools/agents/micronauts",
  "version": 4,
  "atlasSize": 1024,
  "vocabSize": 1024,
  "langBase": 128,
  "langSlots": 896,
  "langScheme": "word_hash_mod_896_plus_128",

  "int4_hotpath": {
    "_comment": "INT4 gram nibbles (0-15) map directly to scalar compute tier tokens 0x010-0x01F",
    "nibble_offset": 16,
    "nibble_to_token": "nibble + 0x10"
  },

  "tiers": [
    { "id": 0, "name": "control",   "range": [0,   15],  "class": 2, "desc": "Language control tokens" },
    { "id": 1, "name": "compute",   "range": [16,  31],  "class": 0, "desc": "Scalar compute ops (INT4 hot path at nibble=id-16)" },
    { "id": 2, "name": "vector",    "range": [32,  47],  "class": 0, "desc": "Vector compute ops" },
    { "id": 3, "name": "tools",     "range": [48,  79],  "class": 1, "desc": "Claude Code tool invocations" },
    { "id": 4, "name": "agents",    "range": [80,  95],  "class": 1, "desc": "Agent / skill / cron ops" },
    { "id": 5, "name": "micronauts","range": [96,  111], "class": 1, "desc": "Micronaut / XCFE / SCXQ2 ops" },
    { "id": 6, "name": "commands",  "range": [112, 127], "class": 2, "desc": "High-level intent / command tokens" },
    { "id": 7, "name": "language",  "range": [128, 1023],"class": 5, "desc": "Word hash slots (word_hash mod 896 + 128)" }
  ],

  "classMap": {
    "compute":  0,
    "memory":   1,
    "control":  2,
    "tool":     3,
    "agent":    4,
    "language": 5
  },

  "tokens": [
    { "id":   0, "name": "PAD",           "sym": "⊘",  "class": 2, "tier": 0, "desc": "Padding token" },
    { "id":   1, "name": "BOS",           "sym": "⟨",  "class": 2, "tier": 0, "desc": "Begin of sequence" },
    { "id":   2, "name": "EOS",           "sym": "⟩",  "class": 2, "tier": 0, "desc": "End of sequence" },
    { "id":   3, "name": "UNK",           "sym": "?",  "class": 2, "tier": 0, "desc": "Unknown token" },
    { "id":   4, "name": "SEP",           "sym": "|",  "class": 2, "tier": 0, "desc": "Separator / turn boundary" },
    { "id":   5, "name": "MASK",          "sym": "█",  "class": 2, "tier": 0, "desc": "Mask token (MLM)" },
    { "id":   6, "name": "NL",            "sym": "↵",  "class": 2, "tier": 0, "desc": "Newline" },
    { "id":   7, "name": "CODE_START",    "sym": "⌜",  "class": 2, "tier": 0, "desc": "Code block open" },
    { "id":   8, "name": "CODE_END",      "sym": "⌟",  "class": 2, "tier": 0, "desc": "Code block close" },
    { "id":   9, "name": "QUOTE_START",   "sym": "«",  "class": 2, "tier": 0, "desc": "Quoted text open" },
    { "id":  10, "name": "QUOTE_END",     "sym": "»",  "class": 2, "tier": 0, "desc": "Quoted text close" },
    { "id":  11, "name": "TOOL_CALL",     "sym": "⟁",  "class": 2, "tier": 0, "desc": "Tool invocation start (KLSL sigil)" },
    { "id":  12, "name": "TOOL_RESULT",   "sym": "⟂",  "class": 2, "tier": 0, "desc": "Tool result start" },
    { "id":  13, "name": "THINK_START",   "sym": "⟪",  "class": 2, "tier": 0, "desc": "Reasoning chain open" },
    { "id":  14, "name": "THINK_END",     "sym": "⟫",  "class": 2, "tier": 0, "desc": "Reasoning chain close" },
    { "id":  15, "name": "NOP",           "sym": "·",  "class": 2, "tier": 0, "desc": "No-op / filler" },

    { "id":  16, "name": "LOAD",          "sym": "↓",  "class": 0, "tier": 1, "desc": "Load scalar from memory", "nibble": 0 },
    { "id":  17, "name": "SCALE",         "sym": "×",  "class": 0, "tier": 1, "desc": "Scale by constant",        "nibble": 1 },
    { "id":  18, "name": "ACCUM",         "sym": "Σ",  "class": 0, "tier": 1, "desc": "Accumulate into register", "nibble": 2 },
    { "id":  19, "name": "RELU",          "sym": "⌈",  "class": 0, "tier": 1, "desc": "ReLU activation",          "nibble": 3 },
    { "id":  20, "name": "ADD",           "sym": "+",  "class": 0, "tier": 1, "desc": "Scalar add",               "nibble": 4 },
    { "id":  21, "name": "MUL",           "sym": "*",  "class": 0, "tier": 1, "desc": "Scalar multiply",          "nibble": 5 },
    { "id":  22, "name": "DIV",           "sym": "÷",  "class": 0, "tier": 1, "desc": "Scalar divide",            "nibble": 6 },
    { "id":  23, "name": "EMIT",          "sym": "→",  "class": 0, "tier": 1, "desc": "Write to output buffer",   "nibble": 7 },
    { "id":  24, "name": "READ_S",        "sym": "◀",  "class": 1, "tier": 1, "desc": "Read scalar from slot",    "nibble": 8 },
    { "id":  25, "name": "WRITE_S",       "sym": "▶",  "class": 1, "tier": 1, "desc": "Write scalar to slot",     "nibble": 9 },
    { "id":  26, "name": "BRANCH",        "sym": "⤷",  "class": 2, "tier": 1, "desc": "Conditional branch",       "nibble": 10 },
    { "id":  27, "name": "HALT",          "sym": "⊠",  "class": 2, "tier": 1, "desc": "Halt gram execution",      "nibble": 11 },
    { "id":  28, "name": "RETURN",        "sym": "⤶",  "class": 2, "tier": 1, "desc": "Return from sub-gram",     "nibble": 12 },
    { "id":  29, "name": "CALL",          "sym": "⤵",  "class": 2, "tier": 1, "desc": "Call sub-gram",            "nibble": 13 },
    { "id":  30, "name": "PUSH",          "sym": "⊕",  "class": 1, "tier": 1, "desc": "Push to stack",            "nibble": 14 },
    { "id":  31, "name": "POP",           "sym": "⊖",  "class": 1, "tier": 1, "desc": "Pop from stack",           "nibble": 15 },

    { "id":  32, "name": "DOT",           "sym": "·",  "class": 0, "tier": 2, "desc": "Vector dot product → scalar" },
    { "id":  33, "name": "LEN",           "sym": "|v|","class": 0, "tier": 2, "desc": "Vector length" },
    { "id":  34, "name": "NORM",          "sym": "v̂",  "class": 0, "tier": 2, "desc": "Normalize in-place" },
    { "id":  35, "name": "VSUB",          "sym": "−",  "class": 0, "tier": 2, "desc": "Vector subtract" },
    { "id":  36, "name": "LERP",          "sym": "∫",  "class": 0, "tier": 2, "desc": "Linear interpolate" },
    { "id":  37, "name": "CROSS",         "sym": "×v", "class": 0, "tier": 2, "desc": "Cross product" },
    { "id":  38, "name": "PROJ",          "sym": "π",  "class": 0, "tier": 2, "desc": "Project vector onto axis" },
    { "id":  39, "name": "EXP",           "sym": "eˣ", "class": 0, "tier": 2, "desc": "Element-wise exp" },
    { "id":  40, "name": "VSUM",          "sym": "Σv", "class": 0, "tier": 2, "desc": "Sum of vector elements" },
    { "id":  41, "name": "VDIV",          "sym": "÷v", "class": 0, "tier": 2, "desc": "Element-wise divide" },
    { "id":  42, "name": "RSQRT",         "sym": "1/√","class": 0, "tier": 2, "desc": "Reciprocal square root" },
    { "id":  43, "name": "CLAMP",         "sym": "[·]","class": 0, "tier": 2, "desc": "Clamp to [0,1]" },
    { "id":  44, "name": "MAX4",          "sym": "⊤",  "class": 0, "tier": 2, "desc": "Element-wise max" },
    { "id":  45, "name": "MIN4",          "sym": "⊥",  "class": 0, "tier": 2, "desc": "Element-wise min" },
    { "id":  46, "name": "FMADD",         "sym": "⊛",  "class": 0, "tier": 2, "desc": "Fused multiply-add" },
    { "id":  47, "name": "SOFTMAX",       "sym": "∫e", "class": 0, "tier": 2, "desc": "Stable softmax over float4" },

    { "id":  48, "name": "T_READ",        "sym": "📄", "class": 3, "tier": 3, "desc": "Tool: Read file" },
    { "id":  49, "name": "T_WRITE",       "sym": "💾", "class": 3, "tier": 3, "desc": "Tool: Write file" },
    { "id":  50, "name": "T_EDIT",        "sym": "✏",  "class": 3, "tier": 3, "desc": "Tool: Edit file (patch)" },
    { "id":  51, "name": "T_GLOB",        "sym": "🔍", "class": 3, "tier": 3, "desc": "Tool: Glob file search" },
    { "id":  52, "name": "T_GREP",        "sym": "🔎", "class": 3, "tier": 3, "desc": "Tool: Grep content search" },
    { "id":  53, "name": "T_BASH",        "sym": "$",  "class": 3, "tier": 3, "desc": "Tool: Bash execute" },
    { "id":  54, "name": "T_BASH_BG",     "sym": "$&", "class": 3, "tier": 3, "desc": "Tool: Bash background task" },
    { "id":  55, "name": "T_WEB_FETCH",   "sym": "🌐", "class": 3, "tier": 3, "desc": "Tool: WebFetch URL" },
    { "id":  56, "name": "T_WEB_SEARCH",  "sym": "🔗", "class": 3, "tier": 3, "desc": "Tool: WebSearch query" },
    { "id":  57, "name": "T_ASK",         "sym": "❓", "class": 3, "tier": 3, "desc": "Tool: Ask user question" },
    { "id":  58, "name": "T_NB_EDIT",     "sym": "📓", "class": 3, "tier": 3, "desc": "Tool: NotebookEdit" },
    { "id":  59, "name": "T_MCP_CALL",    "sym": "⚡", "class": 3, "tier": 3, "desc": "Tool: MCP tool call" },
    { "id":  60, "name": "T_MCP_RES",     "sym": "⚙",  "class": 3, "tier": 3, "desc": "Tool: Read MCP resource" },
    { "id":  61, "name": "T_REMOTE",      "sym": "📡", "class": 3, "tier": 3, "desc": "Tool: RemoteTrigger" },
    { "id":  62, "name": "T_TOOL_SEARCH", "sym": "🛠",  "class": 3, "tier": 3, "desc": "Tool: ToolSearch (deferred)" },
    { "id":  63, "name": "T_SKILL",       "sym": "⭐", "class": 3, "tier": 3, "desc": "Tool: Skill invocation" },

    { "id":  64, "name": "T_TASK_CREATE", "sym": "✚",  "class": 3, "tier": 3, "desc": "Tool: TaskCreate" },
    { "id":  65, "name": "T_TASK_UPDATE", "sym": "✎",  "class": 3, "tier": 3, "desc": "Tool: TaskUpdate" },
    { "id":  66, "name": "T_TASK_GET",    "sym": "📋", "class": 3, "tier": 3, "desc": "Tool: TaskGet" },
    { "id":  67, "name": "T_TASK_LIST",   "sym": "≡",  "class": 3, "tier": 3, "desc": "Tool: TaskList" },
    { "id":  68, "name": "T_TASK_STOP",   "sym": "⬛", "class": 3, "tier": 3, "desc": "Tool: TaskStop" },
    { "id":  69, "name": "T_TASK_OUT",    "sym": "📤", "class": 3, "tier": 3, "desc": "Tool: TaskOutput" },
    { "id":  70, "name": "T_PLAN_ENTER",  "sym": "⟦",  "class": 3, "tier": 3, "desc": "Tool: EnterPlanMode" },
    { "id":  71, "name": "T_PLAN_EXIT",   "sym": "⟧",  "class": 3, "tier": 3, "desc": "Tool: ExitPlanMode" },
    { "id":  72, "name": "T_WT_ENTER",    "sym": "⇥",  "class": 3, "tier": 3, "desc": "Tool: EnterWorktree" },
    { "id":  73, "name": "T_WT_EXIT",     "sym": "⇤",  "class": 3, "tier": 3, "desc": "Tool: ExitWorktree" },
    { "id":  74, "name": "T_CONFIG",      "sym": "⚙",  "class": 3, "tier": 3, "desc": "Tool: Config read/write" },
    { "id":  75, "name": "T_CRON_ADD",    "sym": "⏰", "class": 3, "tier": 3, "desc": "Tool: CronCreate" },
    { "id":  76, "name": "T_CRON_DEL",    "sym": "⏱",  "class": 3, "tier": 3, "desc": "Tool: CronDelete" },
    { "id":  77, "name": "T_CRON_LIST",   "sym": "⏲",  "class": 3, "tier": 3, "desc": "Tool: CronList" },
    { "id":  78, "name": "T_AGENT_SPAWN", "sym": "🤖", "class": 4, "tier": 4, "desc": "Agent: spawn subagent" },
    { "id":  79, "name": "T_AGENT_MSG",   "sym": "💬", "class": 4, "tier": 4, "desc": "Agent: send message" },

    { "id":  80, "name": "T_AGENT_WAIT",  "sym": "⏳", "class": 4, "tier": 4, "desc": "Agent: wait for result" },
    { "id":  81, "name": "T_AGENT_KILL",  "sym": "✕",  "class": 4, "tier": 4, "desc": "Agent: kill subagent" },
    { "id":  82, "name": "T_AGENT_RES",   "sym": "✓",  "class": 4, "tier": 4, "desc": "Agent: result received" },
    { "id":  83, "name": "SKILL_CALL",    "sym": "⚡s", "class": 4, "tier": 4, "desc": "Skill: invoke named skill" },
    { "id":  84, "name": "SKILL_LOAD",    "sym": "↓s", "class": 4, "tier": 4, "desc": "Skill: load skill def" },
    { "id":  85, "name": "SKILL_LIST",    "sym": "≡s", "class": 4, "tier": 4, "desc": "Skill: list available" },
    { "id":  86, "name": "SKILL_RES",     "sym": "✓s", "class": 4, "tier": 4, "desc": "Skill: result" },
    { "id":  87, "name": "SCHED_AGENT",   "sym": "📆", "class": 4, "tier": 4, "desc": "Schedule: remote agent" },
    { "id":  88, "name": "REMOTE_TRIG",   "sym": "📡t","class": 4, "tier": 4, "desc": "RemoteTrigger invocation" },
    { "id":  89, "name": "PERM_ADD",      "sym": "🔓", "class": 4, "tier": 4, "desc": "Permissions: add allow" },
    { "id":  90, "name": "PERM_DEL",      "sym": "🔒", "class": 4, "tier": 4, "desc": "Permissions: remove" },
    { "id":  91, "name": "ENV_SET",       "sym": "🌿", "class": 4, "tier": 4, "desc": "Environment variable set" },
    { "id":  92, "name": "HOOK_ADD",      "sym": "🪝",  "class": 4, "tier": 4, "desc": "Hook: register event hook" },
    { "id":  93, "name": "HOOK_DEL",      "sym": "🪝x", "class": 4, "tier": 4, "desc": "Hook: remove event hook" },
    { "id":  94, "name": "MEM_READ",      "sym": "🧠r","class": 4, "tier": 4, "desc": "Memory: read from memory file" },
    { "id":  95, "name": "MEM_WRITE",     "sym": "🧠w","class": 4, "tier": 4, "desc": "Memory: write to memory file" },

    { "id":  96, "name": "ATLAS_INIT",    "sym": "⊞",  "class": 0, "tier": 5, "desc": "XCFE: load glyph atlas to GPU" },
    { "id":  97, "name": "GRAM_EXEC",     "sym": "⊟",  "class": 0, "tier": 5, "desc": "XCFE: execute gram stream" },
    { "id":  98, "name": "GLYPH_DISP",    "sym": "⊠",  "class": 0, "tier": 5, "desc": "XCFE: dispatch glyph primitives" },
    { "id":  99, "name": "K_AYAB",        "sym": "K'", "class": 2, "tier": 5, "desc": "XCFE: K'ayab' loop construct" },
    { "id": 100, "name": "SHARD_LOAD",    "sym": "⇊",  "class": 1, "tier": 5, "desc": "SCXQ2: load shard by hash" },
    { "id": 101, "name": "SHARD_HASH",    "sym": "#",  "class": 1, "tier": 5, "desc": "SCXQ2: resolve layer/head → SHA-256" },
    { "id": 102, "name": "SHARD_FETCH",   "sym": "⇈",  "class": 1, "tier": 5, "desc": "SCXQ2: request shard to triple-buffer" },
    { "id": 103, "name": "SHARD_POLL",    "sym": "⌚", "class": 2, "tier": 5, "desc": "SCXQ2: poll GPU ready" },
    { "id": 104, "name": "SCO_CALL",      "sym": "⊲",  "class": 3, "tier": 5, "desc": "SCO: sidecar call" },
    { "id": 105, "name": "SCO_RESOLVE",   "sym": "⊳",  "class": 3, "tier": 5, "desc": "SCO: resolve sidecar op" },
    { "id": 106, "name": "SCO_AWAIT",     "sym": "⊴",  "class": 2, "tier": 5, "desc": "SCO: await sidecar response" },
    { "id": 107, "name": "SCO_EMIT",      "sym": "⊵",  "class": 1, "tier": 5, "desc": "SCO: emit to sidecar" },
    { "id": 108, "name": "MN_SPAWN",      "sym": "μ+", "class": 4, "tier": 5, "desc": "Micronaut: spawn instance" },
    { "id": 109, "name": "MN_LOAD",       "sym": "μ↓", "class": 1, "tier": 5, "desc": "Micronaut: load model" },
    { "id": 110, "name": "MN_EXEC",       "sym": "μ▶", "class": 0, "tier": 5, "desc": "Micronaut: execute forward pass" },
    { "id": 111, "name": "MN_STOP",       "sym": "μ■", "class": 2, "tier": 5, "desc": "Micronaut: stop / unload" },

    { "id": 112, "name": "CMD_BUILD",     "sym": "🔨", "class": 2, "tier": 6, "desc": "Command: build project" },
    { "id": 113, "name": "CMD_TEST",      "sym": "✅", "class": 2, "tier": 6, "desc": "Command: run tests" },
    { "id": 114, "name": "CMD_DEPLOY",    "sym": "🚀", "class": 2, "tier": 6, "desc": "Command: deploy" },
    { "id": 115, "name": "CMD_COMMIT",    "sym": "📝", "class": 2, "tier": 6, "desc": "Command: git commit" },
    { "id": 116, "name": "CMD_PUSH",      "sym": "⬆",  "class": 2, "tier": 6, "desc": "Command: git push" },
    { "id": 117, "name": "CMD_PULL",      "sym": "⬇",  "class": 2, "tier": 6, "desc": "Command: git pull" },
    { "id": 118, "name": "CMD_BRANCH",    "sym": "⑂",  "class": 2, "tier": 6, "desc": "Command: git branch" },
    { "id": 119, "name": "CMD_MERGE",     "sym": "⑃",  "class": 2, "tier": 6, "desc": "Command: git merge" },
    { "id": 120, "name": "I_QUESTION",    "sym": "?",  "class": 2, "tier": 6, "desc": "Intent: question" },
    { "id": 121, "name": "I_ANSWER",      "sym": "!",  "class": 2, "tier": 6, "desc": "Intent: answer / response" },
    { "id": 122, "name": "I_CODE",        "sym": "</>","class": 2, "tier": 6, "desc": "Intent: code output" },
    { "id": 123, "name": "I_EXPLAIN",     "sym": "∴",  "class": 2, "tier": 6, "desc": "Intent: explanation" },
    { "id": 124, "name": "I_FIX",         "sym": "🔧", "class": 2, "tier": 6, "desc": "Intent: fix / patch" },
    { "id": 125, "name": "I_CREATE",      "sym": "✦",  "class": 2, "tier": 6, "desc": "Intent: create new" },
    { "id": 126, "name": "I_UPDATE",      "sym": "⟳",  "class": 2, "tier": 6, "desc": "Intent: update existing" },
    { "id": 127, "name": "I_ANALYZE",     "sym": "◉",  "class": 2, "tier": 6, "desc": "Intent: analyze / inspect" }
  ],

  "lang_range": {
    "start": 128,
    "end": 1023,
    "count": 896,
    "scheme": "word_hash_mod_896_plus_128",
    "formula": "token_id = (abs(hash(word)) % 896) + 128",
    "collisions": "allowed — multiple words may share a slot",
    "desc": "Word-level language tokens. Each slot encodes one or more natural language words via hash assignment."
  },

  "attention_gram": {
    "desc": "Standard pi-kuhul attention pass — one head — INT4 format",
    "ops": ["READ_S", "READ_S", "ACCUM", "SCALE", "RELU", "READ_S", "ACCUM", "EMIT"],
    "token_ids": [24, 24, 18, 17, 19, 24, 18, 23],
    "nibbles": [8, 8, 2, 1, 3, 8, 2, 7],
    "packed_uint32": "0x72318728",
    "note": "nibble = token_id - 16 (compute tier offset). Lo nibble of byte 0 = first op."
  },

  "ffn_gram": {
    "desc": "Standard pi-kuhul FFN pass — per layer — uint16 format",
    "ops": ["LOAD", "MUL", "RELU", "LOAD", "MUL", "EMIT"],
    "token_ids": [16, 21, 19, 16, 21, 23],
    "packed_uint16s": [16, 21, 19, 16, 21, 23]
  },

  "opcodeClass": {
    "0": "compute",
    "1": "memory",
    "2": "control",
    "3": "tool",
    "4": "agent",
    "5": "language"
  },

  "sentinel_format": {
    "desc": "Control tokens in gram output use bit31 sentinel encoding",
    "format": "outBuffer[base] = 0x80000000 | (pos << 16) | token_id",
    "tokens": [11, 12, 13, 14, 70, 71, 99]
  }
}
